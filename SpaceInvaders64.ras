procedure initializeMonsters();
var
	block_loop_counter, copy_loop_counter : byte;
	source_sprite_ptr, destination_sprite_ptr : ^byte;
begin
	// Copy monster sprite data (frames 1 and 2) into 24 consecutive sprite locations
	// Each of the 12 monster blocks gets 2 animation frames
	for block_loop_counter := 0 to 12 do
	begin
		// Copy frame 1 (sprite index 24 from spritesheet)
		source_sprite_ptr := @spriteLoc + 1536;  // Source: sprite 24
		destination_sprite_ptr := @spriteLoc + (26 + block_loop_counter * 2) * 64;  // Destination: sprite 26, 28, 30, 32...
		for copy_loop_counter := 0 to 63 do
		begin
			destination_sprite_ptr^ := source_sprite_ptr^;
			source_sprite_ptr := source_sprite_ptr + 1;
			destination_sprite_ptr := destination_sprite_ptr + 1;
		end;
		
		// Copy frame 2 (sprite index 25 from spritesheet)
		source_sprite_ptr := @spriteLoc + 1600;  // Source: sprite 25
		destination_sprite_ptr := @spriteLoc + (27 + block_loop_counter * 2) * 64;  // Destination: sprite 27, 29, 31, 33...
		for copy_loop_counter := 0 to 63 do
		begin
			destination_sprite_ptr^ := source_sprite_ptr^;
			source_sprite_ptr := source_sprite_ptr + 1;
			destination_sprite_ptr := destination_sprite_ptr + 1;
		end;
	end;
end;


procedure UpdateSprite();
begin
		
	// Update player position based on joystick input
	player_sprite_x := Helpers::Clamp(player_sprite_x + (joystickright - joystickleft), PLAYER_MIN_X, PLAYER_MAX_X);
	//player_sprite_x := pos_x;
	
	
	// Update the sprite position on screen for sprite number @useSprite	
	SpritePos(player_sprite_x, player_sprite_y, useSprite);
	
	// Set left/right offset pointer for sprite
	/*if (joystickright) then
		player_joystick_direction := 1;
	if (joystickleft) then
		player_joystick_direction := 0;*/
		
	SetSpriteLoc(useSprite, @spriteLoc/64 + 0, useBank);
	//showBullet();
	//animateMonsters();
	
end;

procedure FirePlayerBullet();
begin
	player_bullet_active := 1;
	player_bullet_x := player_sprite_x;  // Same X as player
	player_bullet_y := player_sprite_y - SPRITE_HEIGHT;  // One sprite height above player
	//player_bullet_y := player_sprite_y - 30;  // One sprite height above player
end;

procedure ShowBullet();
var
	bullet_sprite_index : byte;
begin
	// Only display bullet/explosion if the sprite box fits entirely above the player raster line.
	// The VIC-II triggers sprite DMA at the TOP of the sprite box (player_bullet_y), not at the
	// pixel content. DMA runs for SPRITE_HEIGHT (21) lines. If player_bullet_y + SPRITE_HEIGHT >= 224,
	// the DMA window overlaps MainRasterPlayer, which can no longer retrigger sprite 0 for the player
	// at Y=226 that frame -> ship disappears. The guard is: player_bullet_y <= 224 - SPRITE_HEIGHT.
	// (= 203). Note: EXPLOSION_PIXELS_FROM_TOP shifts lit pixels downward inside the box, so the
	// explosion is still visually correct even when the box top is well above the enemy.
	if player_bullet_active <> 0 then
	begin
		//if player_bullet_y <= 224 - SPRITE_HEIGHT then
		//begin
			// Select sprite based on bullet state: 1=normal bullet, 2=explosion
			if player_bullet_active = 2 then
				bullet_sprite_index := 2  // Explosion sprite
			else
				bullet_sprite_index := 1;  // Normal bullet sprite
			
			SetSpriteLoc(useSprite, @spriteLoc/64 + bullet_sprite_index, useBank);
			SpritePos(player_bullet_x, player_bullet_y, useSprite);
		//end;
		// else: sprite box would overlap raster 224 - leave sprite 0 as player
	end;
end;



procedure UpdatePlayerBullet();
begin
	if player_bullet_active = 1 then
	begin
		// Move bullet up
		if player_bullet_y > BULLET_SPEED then
		begin
			player_bullet_y := player_bullet_y - BULLET_SPEED;
		end
		else
		begin
			// Bullet reached top of screen, deactivate
			player_bullet_active := 0;
		end;
	end
	else if player_bullet_active = 2 then
	begin
		// Explosion animation - count frames
		inc(explosion_frame_counter);
		if explosion_frame_counter >= EXPLOSION_DURATION then
		begin
			// Explosion finished, reset bullet
			player_bullet_active := 0;
			explosion_frame_counter := 0;
		end;
	end;
end;

// Enemy shot routines
procedure FireEnemyShot();
var
	es_block_idx: byte;
	es_enemy_idx: byte;
	es_emask: byte;
	es_best_dx: byte;
	es_found_flag: byte;
	es_target_block: byte;
	es_target_enemy: byte;
	es_block_col: byte;
	es_block_row: byte;
	es_enemy_col: byte;
	es_enemy_row: byte;
	es_block_x: byte;
	es_block_y: byte;
	es_candidate_x: byte;
	es_candidate_bottom: byte;
	es_center_x: byte;
	es_bottom_in_sprite: byte;
begin
	if es_shot_active = 0 then
	begin
		// Find alive enemy closest in X to player_sprite_x
		es_found_flag := 0;
		es_best_dx := 255;
		es_block_idx := 0;
		while es_block_idx <= 11 do
		begin
			es_emask := 1;
			es_enemy_idx := 0;
			while es_enemy_idx <= 5 do
			begin
				if (block_enemies[es_block_idx] & es_emask) <> 0 then
				begin
					// compute block col/row
					es_block_row := es_block_idx >> 2; // 0..2
					es_block_col := es_block_idx & 3;  // 0..3
					es_enemy_col := es_enemy_idx >> 1; // 0..2
					es_enemy_row := es_enemy_idx & 1;  // 0 or 1

					es_block_x := monster_base_x + es_block_col * MONSTER_SPACING;
					es_block_y := monster_base_y + es_block_row * MONSTER_ROW_OFFSET + monster_vertical_adjustment;

					// estimate center x of the enemy (col stride = 18px, approximate center offset +6)
					es_center_x := es_block_x + es_enemy_col * 18 + 6;

					// bottom pixel offset depends on top/bottom enemy
					if (es_enemy_row <> 0) then
						es_bottom_in_sprite := 20
					else
						es_bottom_in_sprite := 7;

					es_candidate_bottom := es_block_y + es_enemy_row * 14 + es_bottom_in_sprite;

					// distance in x (absolute)
					if es_center_x >= player_sprite_x then
						es_candidate_x := es_center_x - player_sprite_x
					else
						es_candidate_x := player_sprite_x - es_center_x;

					if es_candidate_x < es_best_dx then
					begin
						es_best_dx := es_candidate_x;
						es_target_block := es_block_idx;
						es_target_enemy := es_enemy_idx;
						es_found_flag := 1;
					end;
				end;
				inc(es_enemy_idx);
				es_emask := es_emask << 1;
			end;
			inc(es_block_idx);
		end;

		if es_found_flag <> 0 then
		begin
			// compute final positions for chosen enemy
			es_block_row := es_target_block >> 2;
			es_block_col := es_target_block & 3;
			es_enemy_col := es_target_enemy >> 1;
			es_enemy_row := es_target_enemy & 1;

			es_block_x := monster_base_x + es_block_col * MONSTER_SPACING;
			es_block_y := monster_base_y + es_block_row * MONSTER_ROW_OFFSET + monster_vertical_adjustment;

			// X snap to middle similarly to explosion centering (approx)
			es_shot_x := es_block_x + es_enemy_col * 18 + 6;

			// Y starts 9 pixels below the lowest point of the enemy
			if (es_enemy_row <> 0) then
				es_bottom_in_sprite := 20
			else
				es_bottom_in_sprite := 7;
			es_shot_y := es_block_y + es_enemy_row * 14 + es_bottom_in_sprite + 9;

			es_shot_anim_index := 0;
			es_shot_move_tick := 0;
			es_shot_active := 1;
		end;
	end;
end;

procedure ShowEnemyShot();
var
	es_sprite_frame_index: byte;
begin
	if es_shot_active <> 0 then
	begin
		if es_shot_active = 1 then
			es_sprite_frame_index := ES_SHOT_ANIM_START + es_shot_anim_index
		else // exploding
			es_sprite_frame_index := 4; // explosion graphic

		SetSpriteLoc(ES_SHOT_SPRITE, @spriteLoc/64 + es_sprite_frame_index, useBank);
		SpritePos(es_shot_x, es_shot_y, ES_SHOT_SPRITE);
	end;
end;

procedure UpdateEnemyShot();
begin
	if es_shot_active = 1 then	
	begin
		inc(es_shot_move_tick);
		if es_shot_move_tick >= ES_SHOT_MOVE_FRAMES then
		begin
			es_shot_move_tick := 0;
			// move down
			es_shot_y := es_shot_y + ES_SHOT_MOVE_PIXELS;
			//es_shot_y := es_shot_y + 1;
			// cycle animation frames 0..3
			es_shot_anim_index := (es_shot_anim_index + 1) & (ES_SHOT_ANIM_FRAMES - 1);

			// If reached bottom of screen -> explode
			if es_shot_y >= (230 - SPRITE_HEIGHT) then
			begin
				es_shot_active := 2;
				es_shot_explode_counter := 0;
			end;
		end;
	end
	else if es_shot_active = 2 then
	begin
		inc(es_shot_explode_counter);
		if es_shot_explode_counter >= ES_SHOT_EXPLODE_DURATION then
		begin
			es_shot_active := 0;
			es_shot_explode_counter := 0;
			// If there are still enemies alive, fire another
			if (INITIAL_INVADER_COUNT - numberOfEnemies) > 0 then
				FireEnemyShot();
		end;
	end;
	//es_shot_y := es_shot_y + 1;
end;

procedure CheckBulletCollision();
var
	block_row : byte;
	block_col : byte;
	block_index : byte;
	enemy_alive : byte;
	block_x : byte;
	block_y : byte;
	rel_x : byte;
	rel_y : byte;
	enemy_col : byte;
	enemy_row : byte;
	hit_enemy_index : byte;
	cbc_enemy_mask : byte;
	should_check : byte;
	found_hit : byte;
begin
	should_check := 1;
	found_hit := 0;
	
	// Early exit if bullet outside enemy formation area.
	// Lower bound: contact pixel (bullet_y + OFFSET) above the formation top -> skip.
	if player_bullet_y + BULLET_Y_CONTACT_OFFSET < monster_base_y + monster_vertical_adjustment then
		should_check := 0;
	// Upper bound: bullet sprite top below the formation bottom -> skip.
	// BYTE OVERFLOW GUARD: monster_base_y(82) + monster_vertical_adjustment + 80 wraps after ~7 drops.
	// Fold the two constants: 82 + 80 = 162, so check becomes bullet_y > adj + 162.
	// adj + 162 overflows when adj > 93 (enemies already off-screen), so skip the guard in that case.
	if monster_vertical_adjustment <= 93 then
	begin
		if player_bullet_y > monster_vertical_adjustment + 162 then
			should_check := 0;
	end;
	
	if should_check <> 0 then
	begin
		// Calculate which block row (0-2) the bullet is in.
		// Use contact pixel Y to avoid byte underflow when sprite top is above the formation.
		rel_y := player_bullet_y + BULLET_Y_CONTACT_OFFSET - monster_base_y - monster_vertical_adjustment;
		if rel_y < MONSTER_ROW_OFFSET then
			block_row := 0
		else if rel_y < MONSTER_ROW_OFFSET * 2 then
			block_row := 1
		else
			block_row := 2;
		
		// Check all 4 blocks in the bullet's row
		block_col := 0;
		while (block_col <= 3 and found_hit = 0) do
		begin
			block_index := block_row * 4 + block_col;
			enemy_alive := block_enemies[block_index];
			
			if enemy_alive <> 0 then
			begin
				block_x := monster_base_x + block_col * MONSTER_SPACING;
				
				// Quick horizontal range check
				// Bullet contact point is BULLET_X_CONTACT_REACH px into the sprite, so effective hit X = player_bullet_x + BULLET_X_CONTACT_REACH.
				// Range: contact point must fall within [block_x, block_x+48).
				// => player_bullet_x in [block_x-REACH, block_x+(48-REACH)). block_x >= 32 so left bound >= 20, no underflow.
				if player_bullet_x >= block_x - BULLET_X_CONTACT_REACH then
					if player_bullet_x < block_x + 48 - BULLET_X_CONTACT_REACH then
					begin
						// rel_x = (player_bullet_x + REACH) - block_x; no underflow since player_bullet_x >= block_x-REACH
						rel_x := player_bullet_x - block_x + BULLET_X_CONTACT_REACH;
						
						block_y := monster_base_y + monster_vertical_adjustment + block_row * MONSTER_ROW_OFFSET;
						// Add BULLET_Y_CONTACT_OFFSET to map sprite top position to actual contact pixel Y.
						// No underflow: bullet enters the row from below so player_bullet_y + offset >= block_y.
						rel_y := player_bullet_y + BULLET_Y_CONTACT_OFFSET - block_y;
						
						// Determine enemy column (0-2) by X position
						// Each enemy is 12px wide with 6px gaps between them
						// Col 0: 0-11, Gap: 12-17, Col 1: 18-29, Gap: 30-35, Col 2: 36-47
						if rel_x < 12 then
							enemy_col := 0
						else if rel_x < 18 then
							enemy_col := $FF  // gap
						else if rel_x < 30 then
							enemy_col := 1
						else if rel_x < 36 then
							enemy_col := $FF  // gap
						else
							enemy_col := 2;
						
						// Determine enemy row (0-1) by Y position
						// Each enemy is 8px tall with a 6px gap between rows (offsets 8-13 in the sprite).
						// BULLET_SPEED=4 can skip the 8-pixel bottom zone entirely when the formation is
						// very low: the bullet jumps from rel_y=13 (gap) to rel_y=9 (gap) to rel_y=5 (top),
						// never passing through range 14-21. Extending the bottom zone upward to rel_y>=8
						// closes the dead zone so odd-indexed (bottom) enemies are always hittable.
						enemy_row := $FF;  // Invalid by default
						if rel_y <= 7 + BULLET_Y_CONTACT_REACH then
							enemy_row := 0
						else if (rel_y >= 8 and rel_y <= 21 + BULLET_Y_CONTACT_REACH) then
							enemy_row := 1;
						
						if (enemy_row <> $FF and enemy_col <> $FF) then
						begin
							hit_enemy_index := enemy_col * 2 + enemy_row;
							cbc_enemy_mask := 1 << hit_enemy_index;
							
							// Check if this enemy is alive
							if (enemy_alive & cbc_enemy_mask) <> 0 then
							begin
								// Hit! Clear enemy and trigger explosion
								// Clear sprite + update block_enemies handled inside ClearMonster
								ClearMonster(block_index, hit_enemy_index);
								// Snap explosion sprite to enemy hitbox top-left.
								// enemy_col stride = 12px wide + 6px gap = 18px.
								// enemy_row stride = 8px tall + 6px gap = 14px.
								// Shift box upward by EXPLOSION_PIXELS_FROM_TOP so the lit pixels
								// (packed at the bottom of the sprite frame) land on the enemy visually.
								player_bullet_x := block_x + enemy_col * 18 - EXPLOSION_X_OFFSET;
								player_bullet_y := block_y + enemy_row * 14 + EXPLOSION_Y_OFFSET - EXPLOSION_PIXELS_FROM_TOP;
								player_bullet_active := 2;
								explosion_frame_counter := 0;
								found_hit := 1;
							end;
						end;
					end;
			end;
			
			inc(block_col);
		end;
	end;
end;

Procedure DisplayText();
begin	
	//moveto(29,1,hi(screen_char_loc));
	Screen::PrintString(" ",29,0,#Screen::screen0);
	
	Screen::PrintString("  SCORE(1)",29,1,#Screen::screen0);		
	
	Screen::PrintString("  HI-SCORE",29,11,#Screen::screen0);
	Screen::PrintString("      1740",29,13,#Screen::screen0);
	
	Screen::PrintString("  SCORE(2)",29,21,#Screen::screen0);
	Screen::PrintString("      1740",29,23,#Screen::screen0);

	Screen::PrintString("lmn",4,19,#Screen::screen0);
	Screen::PrintString("opq",4,20,#Screen::screen0);
	
	Screen::PrintString("rst",10,19,#Screen::screen0);
	Screen::PrintString("uvw",10,20,#Screen::screen0);
	
	Screen::PrintString("xyz",16,19,#Screen::screen0);
