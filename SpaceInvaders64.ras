	Screen::PrintString("¤%&",22,19,#Screen::screen0);
	Screen::PrintString("/+*",22,20,#Screen::screen0);
	
	Screen::PrintString("ooooooooooooooooooooooooooooo",0,24,#Screen::screen0);	
end;

procedure ClearEnemyAtCounter();
var
	clear_index : byte;
	clear_col : byte;
	clear_local_index : byte;
	clear_row : byte;
	enemy_type : byte;
	pair_index : byte;
	sub_local : byte;
	enemy_sub : byte;
	cec_enemy_mask : byte;
	temp_block_index : byte = 0;
	temp_enemy_index : byte = 0;
begin
	clear_index := 71 - sequential_clear_counter;
	clear_col := 3 - Helpers::Div(clear_index, 18);
	clear_local_index := Helpers::Mod(clear_index, 18);
	pair_index := Helpers::Div(clear_local_index, 6);
	sub_local := Helpers::Mod(clear_local_index, 6);
	// Map local sub-index to block row (0=top,1=middle,2=bottom)
	clear_row := Helpers::Div(sub_local, 2);
	enemy_sub := Helpers::Mod(sub_local, 2);
	// Column-based enemy indexing: Col0(0,1), Col1(2,3), Col2(4,5)
	// Clear from right to left, bottom then top within each column
	if pair_index = 0 then
	begin
		if enemy_sub = 0 then enemy_type := 5 else enemy_type := 4;  // Right column
	end
	else if pair_index = 1 then
	begin
		if enemy_sub = 0 then enemy_type := 3 else enemy_type := 2;  // Middle column
	end
	else
	begin
		if enemy_sub = 0 then enemy_type := 1 else enemy_type := 0;  // Left column
	end;
	temp_enemy_index := enemy_type;
	// block_enemies is row-major with row 0 = TOP. The clearing sequence
	// should still clear bottom-first visually, so map the computed row
	// (0=top..2=bottom) to the block index accordingly.
	temp_block_index := clear_col + (2 - clear_row) * 4;
	// Only clear if this enemy is still alive according to block_enemies
	cec_enemy_mask := 1 << temp_enemy_index;
	if (block_enemies[temp_block_index] & cec_enemy_mask) <> 0 then
	begin
		// ClearMonster will clear the sprite and update the block_enemies bitmask
		ClearMonster(temp_block_index, temp_enemy_index);
	end;
end;

// Find the rightmost occupied enemy column offset (0-172)
// Returns pixel offset from monster_base_x to the rightmost enemy
function GetRightmostEnemyOffset() : byte;
var
	rightmost_block_column : byte;
	rightmost_row_index : byte;
	rightmost_block_index : byte;
	rightmost_enemies_byte : byte;
	rightmost_found_flag : byte;
	rightmost_result_offset : byte;
	rightmost_column_loop_done : byte;
begin
	rightmost_found_flag := 0;
	rightmost_result_offset := 0;
	rightmost_column_loop_done := 0;
	// Scan from rightmost block column (3) to left (0)
	rightmost_block_column := 3;
	while (rightmost_column_loop_done = 0) do
	begin
		// Check all 3 rows for this block column
		rightmost_row_index := 0;
		while (rightmost_row_index < 3 and rightmost_found_flag = 0) do
		begin
			rightmost_block_index := rightmost_block_column + rightmost_row_index * 4;
			rightmost_enemies_byte := block_enemies[rightmost_block_index];
			// Column-based indexing: check right to left
			if (rightmost_enemies_byte & $30) <> 0 then  // bits 4,5 set (right column: enemies 4,5)
			begin
				rightmost_result_offset := rightmost_block_column * 54 + 36;
				rightmost_found_flag := 1;
			end
			else if (rightmost_enemies_byte & $0C) <> 0 then  // bits 2,3 set (middle column: enemies 2,3)
			begin
				rightmost_result_offset := rightmost_block_column * 54 + 18;
				rightmost_found_flag := 1;
			end
			else if (rightmost_enemies_byte & $03) <> 0 then  // bits 0,1 set (left column: enemies 0,1)
			begin
				rightmost_result_offset := rightmost_block_column * 54;
				rightmost_found_flag := 1;
			end;
			inc(rightmost_row_index);
		end;
		// Exit if found or if we've checked column 0
		if (rightmost_found_flag = 1 or rightmost_block_column = 0) then
			rightmost_column_loop_done := 1
		else
			dec(rightmost_block_column);
	end;
	GetRightmostEnemyOffset := rightmost_result_offset;
end;

// Find the leftmost occupied enemy column offset (0-172)
function GetLeftmostEnemyOffset() : byte;
var
	leftmost_block_column : byte;
	leftmost_row_index : byte;
	leftmost_block_index : byte;
	leftmost_enemies_byte : byte;
	leftmost_found_flag : byte;
	leftmost_result_offset : byte;
	leftmost_column_loop_done : byte;
begin
	leftmost_found_flag := 0;
	leftmost_result_offset := 0;
	leftmost_column_loop_done := 0;
	// Scan from leftmost block column (0) to right (3)
	leftmost_block_column := 0;
	while (leftmost_column_loop_done = 0) do
	begin
		// Check all 3 rows for this block column
		leftmost_row_index := 0;
		while (leftmost_row_index < 3 and leftmost_found_flag = 0) do
		begin
			leftmost_block_index := leftmost_block_column + leftmost_row_index * 4;
			leftmost_enemies_byte := block_enemies[leftmost_block_index];
			// Column-based indexing: check left to right
			if (leftmost_enemies_byte & $03) <> 0 then  // bits 0,1 set (left column: enemies 0,1)
			begin
				leftmost_result_offset := leftmost_block_column * 54;
				leftmost_found_flag := 1;
			end
			else if (leftmost_enemies_byte & $0C) <> 0 then  // bits 2,3 set (middle column: enemies 2,3)
			begin
				leftmost_result_offset := leftmost_block_column * 54 + 18;
				leftmost_found_flag := 1;
			end
			else if (leftmost_enemies_byte & $30) <> 0 then  // bits 4,5 set (right column: enemies 4,5)
			begin
				leftmost_result_offset := leftmost_block_column * 54 + 36;
				leftmost_found_flag := 1;
			end;
			inc(leftmost_row_index);
		end;
		// Exit if found or if we've checked column 3
		if (leftmost_found_flag = 1 or leftmost_block_column = 3) then
			leftmost_column_loop_done := 1
		else
			inc(leftmost_block_column);
	end;
	GetLeftmostEnemyOffset := leftmost_result_offset;
end;

// Returns 1 if any enemy remains in the specified row (0=top,1=middle,2=bottom)
function RowHasMonsters(row: byte) : byte;
var
	col: byte;
	idx: byte;
	has_flag: byte;
begin

	has_flag := 0;
	col := 0;
	while (col < 4) do
	begin
		idx := row * 4 + col;
		if block_enemies[idx] <> 0 then
		begin
			has_flag := 1;
			col := 4; // break
		end;
		inc(col);
	end;
	RowHasMonsters := has_flag;
end;

// Returns the Y pixel coordinate of the bottom edge of the lowest alive enemy.
// Scans monster rows bottom-to-top; byte underflow (dec past 0 -> 255) exits the loop naturally.
// Used to clamp formation drops so enemies never reach the player.
function GetLowestEnemyBottomY() : byte;
var
	gleby_r : byte;
	gleby_b : byte;
	gleby_found : byte;
	gleby_lowest_row : byte;
	gleby_row_offset : byte;
	gleby_has_bottom_enemy : byte;
	gleby_bottom_in_sprite : byte;
	gleby_result : byte;
begin
	gleby_found := 0;
	gleby_lowest_row := 0;
	gleby_r := 2;
	// Scan from bottom row (2) upward; dec past 0 wraps to 255 which exits 'r <= 2'
	while (gleby_r <= 2 and gleby_found = 0) do
	begin
		gleby_b := 0;
		while (gleby_b <= 3 and gleby_found = 0) do
		begin
			if block_enemies[gleby_r * 4 + gleby_b] <> 0 then
			begin
				gleby_lowest_row := gleby_r;
				gleby_found := 1;
			end;
			inc(gleby_b);
		end;
		if gleby_found = 0 then
			dec(gleby_r);  // at r=0 wraps to 255, exiting the while
	end;

	// Row Y offsets: row 0 = 0, row 1 = MONSTER_ROW_OFFSET, row 2 = MONSTER_ROW_OFFSET*2
	if gleby_lowest_row = 0 then
		gleby_row_offset := 0
	else if gleby_lowest_row = 1 then
		gleby_row_offset := MONSTER_ROW_OFFSET
	else
		gleby_row_offset := MONSTER_ROW_OFFSET * 2;

	// Check whether any 'bottom' enemy (odd index; bits 1,3,5 = mask $2A) is alive in this row.
	// Bottom enemies occupy sprite pixel rows 13-20 (bottom pixel offset = 20).
	// Top-only enemies occupy rows 0-7 (bottom pixel offset = 7).
	gleby_has_bottom_enemy := 0;
	gleby_b := 0;
	while gleby_b <= 3 do
	begin
		if (block_enemies[gleby_lowest_row * 4 + gleby_b] & $2A) <> 0 then
			gleby_has_bottom_enemy := 1;
		inc(gleby_b);
	end;

	if gleby_has_bottom_enemy <> 0 then
		gleby_bottom_in_sprite := 20
	else
		gleby_bottom_in_sprite := 7;

	gleby_result := monster_base_y + gleby_row_offset + monster_vertical_adjustment + gleby_bottom_in_sprite;
	GetLowestEnemyBottomY := gleby_result;
end;

procedure UpdateTick();
var
	should_move_enemy : byte;
	rightmost_offset : byte;
	leftmost_offset : byte;
	right_edge : byte;
	left_edge : byte;
	prev_direction : byte;
begin
	should_move_enemy := 0;
	
	if enemyMoveCounter <> 0 then
	begin
		dec(enemyMoveCounter);
		
		// Calculate actual enemy formation edges based on remaining enemies
		rightmost_offset := GetRightmostEnemyOffset();
		leftmost_offset := GetLeftmostEnemyOffset();
		right_edge := monster_base_x + rightmost_offset + 10;  // +10 for double-width enemy (5 sprite pixels × 2)
		left_edge := monster_base_x + leftmost_offset;
		// Boundaries set so all enemy configurations bounce at the same visual offset from each wall (36px).
		// Left: bounce when leftmost enemy visual edge <= 36 (i.e. left_edge <= 36).
		// Right: symmetric restriction, 12px inward from original 254 = 242.
		// No byte overflow risk: right boundary caps monster_base_x low enough that left_edge sum stays < 255.
		prev_direction := enemy_direction;
		if right_edge >= 242 then
			enemy_direction := 0
		else if left_edge <= 36 then
			enemy_direction := 1;

		// If direction changed, drop the formation by MONSTER_DROP_AMOUNT pixels
		if prev_direction <> enemy_direction then
		begin
			// ENABLE_DROP_FLOOR: only drop if the lowest enemy's bottom pixel, after the drop,
			// would still be at least 1 pixel above the player's top pixel.
			// Safe byte check: lowest_bottom_y < player_sprite_y - MONSTER_DROP_AMOUNT - 1
			if ENABLE_DROP_FLOOR <> 0 then
			begin
				if GetLowestEnemyBottomY() < player_sprite_y - MONSTER_DROP_AMOUNT - 0 then // Adjust this to tune where the drops stop
					monster_vertical_adjustment := monster_vertical_adjustment + MONSTER_DROP_AMOUNT;
			end
			else
				monster_vertical_adjustment := monster_vertical_adjustment + MONSTER_DROP_AMOUNT;
		end;
			
		if enemyMoveCounter = 2 then
			should_move_enemy := 1;
	end
	else begin
		enemyMoveCounter := (INITIAL_INVADER_COUNT - numberOfEnemies);
				
		monster_animation_frame := monster_animation_frame xor 1;
		
		// Update sprite pointers for row 0 - rows 1 and 2 are updated in raster interrupt
		// Each row uses different sprite blocks: row 0 (3-10), row 1 (11-18), row 2 (19-26)
		AnimateMonsters(0); // Row 0 uses sprites based on row parameter
		
		// Clear enemies based on ENEMIES_TO_CLEAR constant
		if sequential_clear_counter > (71 - ENEMIES_TO_CLEAR) then
		begin
			ClearEnemyAtCounter();
			dec(sequential_clear_counter);
			
			
		end;
		
		should_move_enemy := 1;
	end;
	
	if should_move_enemy <> 0 then
	begin
		// At maximum speed (moving every 1-2 frames), move 2 pixels to match player speed
		// At slower speeds, move 1 pixel
		if (INITIAL_INVADER_COUNT - numberOfEnemies) <= 2 then
		begin
			if (enemy_direction <> 0) then
				monster_base_x := monster_base_x + 2
			else
				monster_base_x := monster_base_x - 2;
		end
		else
		begin
			if (enemy_direction <> 0) then
				inc(monster_base_x)
			else
				dec(monster_base_x);
		end;
	end;
end;



procedure MakeMonsters();
var 
	monster_sprite_color : byte = cyan;
	
begin
	monster_base_y := 82;
	monster_base_x := 18;
	
	sprite_color[useSprite]:= monster_sprite_color;
	
	// Set sprite colors
	sprite_color[monsterSprite1]:= monster_sprite_color;
	sprite_color[monsterSprite2]:= monster_sprite_color;
	sprite_color[monsterSprite3]:= monster_sprite_color;
	sprite_color[monsterSprite4]:= monster_sprite_color;
	  
	// Enable all monster sprites
	togglebit(sprite_bitmask,monsterSprite1,1);
	togglebit(sprite_bitmask,monsterSprite2,1);
	togglebit(sprite_bitmask,monsterSprite3,1);
	togglebit(sprite_bitmask,monsterSprite4,1);
	
	// Enable sprite stretching for wider monsters
	togglebit(SPRITE_STRETCH_X,monsterSprite1,1);
	togglebit(SPRITE_STRETCH_X,monsterSprite2,1);
	togglebit(SPRITE_STRETCH_X,monsterSprite3,1);
	togglebit(SPRITE_STRETCH_X,monsterSprite4,1);	
		
end;

// ---------------------------------------------------------------------------------------------------------------------------------
// Main raster interrupt routines.
// ---------------------------------------------------------------------------------------------------------------------------------

interrupt MainRasterChain();
begin
	StartIRQ(@useKernal);	
	if debug_enable_bgcol = 1 then
		SCREEN_BG_COL := BLACK;
		
	ShowBullet();

	
	//border_debug_color := peek(^$D01E, 0);
	//SCREEN_BG_COL := border_debug_color;
	//DisplayScore();
	// Clear sprite collision registers to remove garbage data
	//asm(" lda $D01E");
	//asm(" lda $D01F");

	UpdatePlayerBullet();

	
	// Lightweight joystick update only
	//Memory::Fill(#joystickup,0,5);
	Joystick(joystickPort);
		
	// Check fire button with debounce (only fire on button press, not hold)    
	if (joystickbutton=1) then
	begin
		
		if (previous_fire_state = 0 and player_bullet_active = 0) then		
		begin
			FirePlayerBullet();
			//inc(border_debug_color);
		end;
		previous_fire_state := 1;
	end
	else
		previous_fire_state := 0;

	// If no enemy shot active and enemies remain, fire one
	if es_shot_active = 0 then
	begin
		if (INITIAL_INVADER_COUNT - numberOfEnemies) > 0 then
			FireEnemyShot();
	end;
	
	/*if player_bullet_active <> 0 then
	begin	
		//SCREEN_BG_COL := border_debug_color;
	end;*/
		
	// Do heavy work at start of frame where we have most time
	// Increment score
	/*Score += SCORE_INCREMENT;
	if (Score >= 10000) then begin
		Score := Score - 10000;
		Score2 += 1;
	end;*/
	
	// Heavy game logic - done here at top of frame
	UpdateTick();
    
	if RowHasMonsters(0) <> 0 then		
		RasterIRQ(MainRasterRow1(), 80, @useKernal)
	else if RowHasMonsters(1) <> 0 then
		RasterIRQ(MainRasterRow2(), 95+monster_vertical_adjustment, @useKernal)
	else if RowHasMonsters(2) <> 0 then
		RasterIRQ(MainRasterRow3(), 121+monster_vertical_adjustment, @useKernal)
	else
		RasterIRQ(MainRasterPlayer(), 223, @useKernal);
	
	// Play music here - called each frame from raster IRQ to advance SID playback
	if debug_enable_bgcol = 0 then
		call(sidfile_1_play);
	
	CloseIRQ();
end;

// This interrupt is triggered one time pr raster cycle
interrupt MainRasterRow1();
begin	
	StartIRQ(@useKernal);	
	if debug_enable_bgcol = 1 then
		SCREEN_BG_COL := RED; 	
	
	// Update first row of monsters only if there are monsters in that row
	if RowHasMonsters(0) <> 0 then
	begin
		UpdateMonsters(0);
		AnimateMonsters(0); // Prepare sprites for row 1
	end;
	
	// Choose next raster handler based on which subsequent rows still have monsters
	if RowHasMonsters(1) <> 0 then
		RasterIRQ(MainRasterRow2(), 95+monster_vertical_adjustment, @useKernal)
	else if RowHasMonsters(2) <> 0 then
		RasterIRQ(MainRasterRow3(), 121+monster_vertical_adjustment, @useKernal)
	else
		RasterIRQ(MainRasterPlayer(), 223, @useKernal);

	CloseIRQ();
end;

interrupt MainRasterRow2();
begin	
	StartIRQ(@useKernal);	
	if debug_enable_bgcol = 1 then
		SCREEN_BG_COL := BLUE;
	//ShowBullet();
	
	//border_debug_color := peek(^$D01E, 0);
	//SCREEN_BG_COL := border_debug_color;
	//DisplayScore();
	

	/*if player_bullet_active <> 0 then
	begin
		ShowBullet();
		//SCREEN_BG_COL := border_debug_color;
	end;*/
	
	
	// Update middle row only if it still contains monsters
	if RowHasMonsters(1) <> 0 then
	begin
		UpdateMonsters(MONSTER_ROW_OFFSET);
		AnimateMonsters(1); // Prepare sprites for row 2
	end;

	// If bottom row still has monsters, go to row3; otherwise skip to joystick handler
	if RowHasMonsters(2) <> 0 then
		RasterIRQ(MainRasterRow3(), 121+monster_vertical_adjustment, @useKernal)
	else
		RasterIRQ(MainRasterPlayer(), 223, @useKernal);

	CloseIRQ();
end;

procedure BorderDebug();
begin
	border_debug_color := peek(^$D01E, 0);
	if debug_enable_bgcol = 1 then
		SCREEN_BG_COL := border_debug_color;
end;

interrupt MainRasterRow3();
begin		
	//BorderDebug();
	if debug_enable_bgcol = 1 then
		SCREEN_BG_COL := GREEN;
	//ShowBullet();

	StartIRQ(@useKernal);
	
	/*if player_bullet_active <> 0 then
	begin
		//SCREEN_BG_COL := border_debug_color;
	end;*/	
	
	// Update bottom row only if it still contains monsters
	if RowHasMonsters(2) <> 0 then
	begin
		UpdateMonsters(MONSTER_ROW_OFFSET*2);
		AnimateMonsters(2); // Prepare sprites for row 3
	end;

	//RasterIRQ(MainRasterJoystick(), 155+monster_vertical_adjustment, @useKernal);
	RasterIRQ(MainRasterPlayer(), 224, @useKernal);
	CloseIRQ();
end;


interrupt MainRasterPlayer();
begin
	UpdateSprite();
	if debug_enable_bgcol = 1 then
		SCREEN_BG_COL := BLACK;
	StartIRQ(@useKernal);	
	//border_debug_color := peek($D01E, 0);
	//SCREEN_BG_COL := border_debug_color;
		

	
	
	//asm(" lda $D01E");
	//asm(" lda $D01F");
	//border_debug_color := peek($D01E, 0);
	//SCREEN_BG_COL := border_debug_color;
			
	//SCREEN_BG_COL := border_debug_color;
	
	// Switch sprite 0 from bullet back to player
	SetSpriteLoc(useSprite, @spriteLoc/64, useBank);  // Player sprite data
	SpritePos(player_sprite_x, player_sprite_y, useSprite);  // Player position

	//togglebit(sprite_bitmask, useSprite, 1);  // Ensure sprite is enabled for player

	RasterIRQ(MainRasterStarfield(),253,@useKernal);
	CloseIRQ();
end;

interrupt MainRasterStarfield();
begin	
		
	//border_debug_color := peek($D01E, 0);
	//SCREEN_BG_COL := border_debug_color;
	//DisplayScore();
	inc(StarField_RasterCount);
	StarField::DoStarfield();    
	preventirq();  
	poke(^$D019, 0, 0);  
	
	// Check collisions AFTER all sprite rows have been displayed
	// Only check when bullet is actively moving (not exploding)
	if player_bullet_active = 1 then
		CheckBulletCollision();
		
	// Update enemy shot movement/animation
	UpdateEnemyShot();
	
	// Show enemy shot sprite if active
	ShowEnemyShot();
	
	RasterIRQ(MainRasterChain(), 0, @useKernal);
end;

// ---------------------------------------------------------------------------------------------------------------------------------
// Main program loop. Turn CIA interrupts off, copy the character set from ROM into RAM and tell the machine to look at CharSetLoc
// for its character set, initialise the pointers and start the raster chain off.
// ---------------------------------------------------------------------------------------------------------------------------------
begin
	MakeSprites();
	
	initializeMonsters();
	//ClearMonster();
	PreclearLeftmostAndBottomEnemies();
	MakeMonsters();
	
	InitSid(sidfile_1_init);
	disableciainterrupts();
	setmemoryconfig(1,0,useKernal);
	
	DisableCIAInterrupts();
	
	SCREEN_BG_COL:=BLACK;
    SCREEN_FG_COL:=BLACK;
	
	// Clear sprite collision registers to remove garbage data
	asm(" lda $D01E");
	asm(" lda $D01F");
	
	StarField::CreateStarScreen();
	
	StarField::StarfieldPtr := #STARFIELD_STAR1INIT;
	StarField::StarfieldPtr2 := #STARFIELD_STAR2INIT;
	StarField::StarfieldPtr3 := #STARFIELD_STAR3INIT;
	StarField::StarfieldPtr4 := #STARFIELD_STAR4INIT;
	
	// IO area visible at $D000-$DFFF, RAM visible at $A000-$BFFF (NO BASIC) and RAM visible at $E000-$FFFF (NO KERNAL). 
	// This is the typical memory configuration for demo/game development. 
	SetMemoryConfig(1, 0, 0);	
	
	EnableRasterIrq();	
	DisplayText();	
	RasterIRQ(MainRasterRow1(),0,@useKernal);
	enableirq();

	// Non-IRQ SID playback (main context). This runs once during init and is safe
	// to execute outside the raster IRQ. Comment/uncomment to test.
	//call(sidfile_1_play); // main-context playback (disabled)
	//call(sidfile_1_play); // alternative: keep commented if you prefer raster IRQ playback

	Loop();
end.