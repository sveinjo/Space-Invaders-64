procedure initializeMonsters();
var
	block_loop_counter, copy_loop_counter : byte;
	source_sprite_ptr, destination_sprite_ptr : ^byte;
begin
	// Copy monster sprite data (frames 1 and 2) into 24 consecutive sprite locations
	// Each of the 12 monster blocks gets 2 animation frames
	for block_loop_counter := 0 to 12 do
	begin
		// Copy frame 1 (sprite index 24 from spritesheet)
		source_sprite_ptr := @spriteLoc + 1536;  // Source: sprite 24
		destination_sprite_ptr := @spriteLoc + (26 + block_loop_counter * 2) * 64;  // Destination: sprite 26, 28, 30, 32...
		for copy_loop_counter := 0 to 63 do
		begin
			destination_sprite_ptr^ := source_sprite_ptr^;
			source_sprite_ptr := source_sprite_ptr + 1;
			destination_sprite_ptr := destination_sprite_ptr + 1;
		end;
		
		// Copy frame 2 (sprite index 25 from spritesheet)
		source_sprite_ptr := @spriteLoc + 1600;  // Source: sprite 25
		destination_sprite_ptr := @spriteLoc + (27 + block_loop_counter * 2) * 64;  // Destination: sprite 27, 29, 31, 33...
		for copy_loop_counter := 0 to 63 do
		begin
			destination_sprite_ptr^ := source_sprite_ptr^;
			source_sprite_ptr := source_sprite_ptr + 1;
			destination_sprite_ptr := destination_sprite_ptr + 1;
		end;
	end;
end;


procedure UpdateSprite();
begin
		
	// Update player position based on joystick input
	player_sprite_x := Helpers::Clamp(player_sprite_x + (joystickright - joystickleft), PLAYER_MIN_X, PLAYER_MAX_X);
	//player_sprite_x := pos_x;
	
	
	// Update the sprite position on screen for sprite number @useSprite	
	SpritePos(player_sprite_x, player_sprite_y, useSprite);
	
	// Set left/right offset pointer for sprite
	/*if (joystickright) then
		player_joystick_direction := 1;
	if (joystickleft) then
		player_joystick_direction := 0;*/
		
	SetSpriteLoc(useSprite, @spriteLoc/64 + 0, useBank);
	//showBullet();
	//animateMonsters();
	
end;

procedure FirePlayerBullet();
begin
	player_bullet_active := 1;
	player_bullet_x := player_sprite_x;  // Same X as player
	player_bullet_y := player_sprite_y - SPRITE_HEIGHT;  // One sprite height above player
	//player_bullet_y := player_sprite_y - 30;  // One sprite height above player
end;

procedure ShowBullet();
var
	bullet_sprite_index : byte;
begin
	// Only display bullet/explosion if the sprite box fits entirely above the player raster line.
	// The VIC-II triggers sprite DMA at the TOP of the sprite box (player_bullet_y), not at the
	// pixel content. DMA runs for SPRITE_HEIGHT (21) lines. If player_bullet_y + SPRITE_HEIGHT >= 224,
	// the DMA window overlaps MainRasterPlayer, which can no longer retrigger sprite 0 for the player
	// at Y=226 that frame -> ship disappears. The guard is: player_bullet_y <= 224 - SPRITE_HEIGHT.
	// (= 203). Note: EXPLOSION_PIXELS_FROM_TOP shifts lit pixels downward inside the box, so the
	// explosion is still visually correct even when the box top is well above the enemy.
	if player_bullet_active <> 0 then
	begin
		//if player_bullet_y <= 224 - SPRITE_HEIGHT then
		//begin
			// Select sprite based on bullet state: 1=normal bullet, 2=explosion
			if player_bullet_active = 2 then
				bullet_sprite_index := 2  // Explosion sprite
			else
				bullet_sprite_index := 1;  // Normal bullet sprite
			
			SetSpriteLoc(useSprite, @spriteLoc/64 + bullet_sprite_index, useBank);
			SpritePos(player_bullet_x, player_bullet_y, useSprite);
		//end;
		// else: sprite box would overlap raster 224 - leave sprite 0 as player
	end;
end;



procedure UpdatePlayerBullet();
begin
	if player_bullet_active = 1 then
	begin
		// Move bullet up
		if player_bullet_y > BULLET_SPEED then
		begin
			player_bullet_y := player_bullet_y - BULLET_SPEED;
		end
		else
		begin
			// Bullet reached top of screen, deactivate
			player_bullet_active := 0;
		end;
	end
	else if player_bullet_active = 2 then
	begin
		// Explosion animation - count frames
		inc(explosion_frame_counter);
		if explosion_frame_counter >= EXPLOSION_DURATION then
		begin
			// Explosion finished, reset bullet
			player_bullet_active := 0;
			explosion_frame_counter := 0;
		end;
	end;
end;


procedure CheckBulletCollision();
var
	block_row : byte;
	block_col : byte;
	block_index : byte;
	enemy_alive : byte;
	block_x : byte;
	block_y : byte;
	rel_x : byte;
	rel_y : byte;
	enemy_col : byte;
	enemy_row : byte;
	hit_enemy_index : byte;
	cbc_enemy_mask : byte;
	should_check : byte;
	found_hit : byte;
begin
	should_check := 1;
	found_hit := 0;

	// Early exit if bullet outside enemy formation area.
	if player_bullet_y + BULLET_Y_CONTACT_OFFSET < monster_base_y then
		should_check := 0;
	// BYTE OVERFLOW GUARD: monster_base_y + 80 wraps when monster_base_y > 175.
	if monster_base_y <= 175 then
	begin
		if player_bullet_y > monster_base_y + 80 then
			should_check := 0;
	end;

	if should_check <> 0 then
	begin
		// Determine block row (0-2) from bullet Y.
		rel_y := player_bullet_y + BULLET_Y_CONTACT_OFFSET - monster_base_y;
		if rel_y < MONSTER_ROW_OFFSET then
			block_row := 0
		else if rel_y < MONSTER_ROW_OFFSET * 2 then
			block_row := 1
		else
			block_row := 2;

		// Scan the 4 block columns in this row. Skip empty blocks immediately.
		block_col := 0;
		while (block_col <= 3 and found_hit = 0) do
		begin
			block_index := block_row * 4 + block_col;
			enemy_alive := block_enemies[block_index];

			if enemy_alive <> 0 then
			begin
				block_x := monster_base_x + block_col * MONSTER_SPACING;

				// Horizontal range check: contact point must fall within [block_x, block_x+48).
				if player_bullet_x >= block_x - BULLET_X_CONTACT_REACH then
					if player_bullet_x < block_x + 48 - BULLET_X_CONTACT_REACH then
					begin
						rel_x := player_bullet_x - block_x + BULLET_X_CONTACT_REACH;

						block_y := monster_base_y + block_row * MONSTER_ROW_OFFSET;
						rel_y := player_bullet_y + BULLET_Y_CONTACT_OFFSET - block_y;

						// Enemy column within block (0-2): 12px wide, 6px gaps.
						if rel_x < 12 then
							enemy_col := 0
						else if rel_x < 18 then
							enemy_col := $FF  // gap
						else if rel_x < 30 then
							enemy_col := 1
						else if rel_x < 36 then
							enemy_col := $FF  // gap
						else
							enemy_col := 2;

						// Enemy row within block (0=top, 1=bottom).
						// Extended bottom zone (rel_y >= 8) closes the dead zone at high BULLET_SPEED.
						enemy_row := $FF;
						if rel_y <= 7 + BULLET_Y_CONTACT_REACH then
							enemy_row := 0
						else if (rel_y >= 8 and rel_y <= 21 + BULLET_Y_CONTACT_REACH) then
							enemy_row := 1;

						if (enemy_row <> $FF and enemy_col <> $FF) then
						begin
							hit_enemy_index := enemy_col * 2 + enemy_row;
							cbc_enemy_mask := 1 << hit_enemy_index;

							if (enemy_alive & cbc_enemy_mask) <> 0 then
							begin
								ClearMonster(block_index, hit_enemy_index);
								player_bullet_x := block_x + enemy_col * 18 - EXPLOSION_X_OFFSET;
								player_bullet_y := block_y + enemy_row * 14 + EXPLOSION_Y_OFFSET - EXPLOSION_PIXELS_FROM_TOP;
								player_bullet_active := 2;
								explosion_frame_counter := 0;
								found_hit := 1;
							end;
						end;
					end;
			end;

			inc(block_col);
		end;
	end;
end;

