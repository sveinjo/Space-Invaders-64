// ---------------------------------------------------------------------------
// ShowGetReadyText
//   Displays "GET READY FOR LEVEL X" centered on screen rows 12-13.
//   Buffers the starfield characters/colors underneath for later restoration.
//
//   IRQ-SAFE: buffer reads and color fills use inline ASM with absolute indexed
//   addressing — no ZP pointers touched.  Screen::PrintString uses ZP $02-$09
//   (Screen unit), not the shared pool.  Level-number digit logic stays Pascal.
//
//   Address constants (baked in — do not change GET_READY_ROW/COL without updating):
//     Line 1 screen $05E8...$05F4  ($0400 + 12*40 + 8,  13 chars)
//     Line 1 color  $D9E8...$D9F4
//     Line 2 screen $0613...$061A  ($0400 + 13*40 + 11,  8 chars)
//     Line 2 color  $DA13...$DA1A
//     Level digit   $0619...$061B  (col 17, 1-3 digits)
//     Level d.color $DA19...$DA1B
//     GET_READY_COLOR = light_blue = $0E
// ---------------------------------------------------------------------------
procedure ShowGetReadyText();
var
	sgrt_level_char : byte;
	sgrt_temp : byte;
	sgrt_text_msg1 : string = ("GET READY FOR");
	sgrt_text_msg2 : string = ("LEVEL ");
begin
	// Disable all sprites to hide them during intermission
	sprite_bitmask := 0;

	// ── Buffer line 1 (13 chars+colors) then print it ────────────────────────
	asm("
        ldx #12
sgrt_buf1 lda $05E8,x
        sta get_ready_char_buffer,x
        lda $D9E8,x
        sta get_ready_color_buffer,x
        dex
        bpl sgrt_buf1
	");
	Screen::PrintString(#sgrt_text_msg1, GET_READY_LINE1_COL, GET_READY_ROW, #Screen::screen0);
	asm("
        ldx #12
        lda #$0E
sgrt_col1 sta $D9E8,x
        dex
        bpl sgrt_col1
	");

	// ── Buffer line 2 (8 chars+colors) then print it ─────────────────────────
	asm("
        ldx #7
sgrt_buf2 lda $0613,x
        sta get_ready_char_buffer+13,x
        lda $DA13,x
        sta get_ready_color_buffer+13,x
        dex
        bpl sgrt_buf2
	");
	Screen::PrintString(#sgrt_text_msg2, GET_READY_LINE2_COL, GET_READY_ROW + 1, #Screen::screen0);

	// ── Level number at col 17 ($0619) — computed, stays Pascal ─────────────
	sgrt_temp := total_level_counter;
	if total_level_counter >= 100 then
	begin
		sgrt_level_char := sgrt_temp / 100;
		poke(^$0619, 0, sgrt_level_char + $30);
		poke(^$DA19, 0, GET_READY_COLOR);
		sgrt_temp := sgrt_temp - (sgrt_level_char * 100);
		sgrt_level_char := sgrt_temp / 10;
		poke(^$061A, 0, sgrt_level_char + $30);
		poke(^$DA1A, 0, GET_READY_COLOR);
		sgrt_temp := sgrt_temp - (sgrt_level_char * 10);
		poke(^$061B, 0, sgrt_temp + $30);
		poke(^$DA1B, 0, GET_READY_COLOR);
	end
	else if total_level_counter >= 10 then
	begin
		sgrt_level_char := sgrt_temp / 10;
		poke(^$0619, 0, sgrt_level_char + $30);
		poke(^$DA19, 0, GET_READY_COLOR);
		sgrt_temp := sgrt_temp - (sgrt_level_char * 10);
		poke(^$061A, 0, sgrt_temp + $30);
		poke(^$DA1A, 0, GET_READY_COLOR);
	end
	else
	begin
		poke(^$0619, 0, total_level_counter + $30);
		poke(^$DA19, 0, GET_READY_COLOR);
	end;

	// ── Line 2 color for "LEVEL " prefix (6 chars $DA13-$DA18) ─────────────
	asm("
        ldx #5
        lda #$0E
sgrt_col2 sta $DA13,x
        dex
        bpl sgrt_col2
	");
end;


// Find the rightmost occupied enemy column offset (0-172)
// Returns pixel offset from monster_base_x to the rightmost enemy
function GetRightmostEnemyOffset() : byte;
var
	rightmost_block_column : byte;
	rightmost_row_index : byte;
	rightmost_block_index : byte;
	rightmost_enemies_byte : byte;
	rightmost_found_flag : byte;
	rightmost_result_offset : byte;
	rightmost_column_loop_done : byte;
begin
	rightmost_found_flag := 0;
	rightmost_result_offset := 0;
	rightmost_column_loop_done := 0;
	// Scan from rightmost block column (3) to left (0)
	rightmost_block_column := 3;
	while (rightmost_column_loop_done = 0) do
	begin
		// Check all 3 rows for this block column
		rightmost_row_index := 0;
		while (rightmost_row_index < 3 and rightmost_found_flag = 0) do
		begin
			rightmost_block_index := rightmost_block_column + rightmost_row_index * 4;
			rightmost_enemies_byte := block_enemies[rightmost_block_index];
			// Column-based indexing: check right to left
			if (rightmost_enemies_byte & $30) <> 0 then  // bits 4,5 set (right column: enemies 4,5)
			begin
				rightmost_result_offset := rightmost_block_column * 54 + 36;
				rightmost_found_flag := 1;
			end
			else if (rightmost_enemies_byte & $0C) <> 0 then  // bits 2,3 set (middle column: enemies 2,3)
			begin
				rightmost_result_offset := rightmost_block_column * 54 + 18;
				rightmost_found_flag := 1;
			end
			else if (rightmost_enemies_byte & $03) <> 0 then  // bits 0,1 set (left column: enemies 0,1)
			begin
				rightmost_result_offset := rightmost_block_column * 54;
				rightmost_found_flag := 1;
			end;
			inc(rightmost_row_index);
		end;
		// Exit if found or if we've checked column 0
		if (rightmost_found_flag = 1 or rightmost_block_column = 0) then
			rightmost_column_loop_done := 1
		else
			dec(rightmost_block_column);
	end;
	GetRightmostEnemyOffset := rightmost_result_offset;
end;

// Find the leftmost occupied enemy column offset (0-172)
function GetLeftmostEnemyOffset() : byte;
var
	leftmost_block_column : byte;
	leftmost_row_index : byte;
	leftmost_block_index : byte;
	leftmost_enemies_byte : byte;
	leftmost_found_flag : byte;
	leftmost_result_offset : byte;
	leftmost_column_loop_done : byte;
begin
	leftmost_found_flag := 0;
	leftmost_result_offset := 0;
	leftmost_column_loop_done := 0;
	// Scan from leftmost block column (0) to right (3)
	leftmost_block_column := 0;
	while (leftmost_column_loop_done = 0) do
	begin
		// Check all 3 rows for this block column
		leftmost_row_index := 0;
		while (leftmost_row_index < 3 and leftmost_found_flag = 0) do
		begin
			leftmost_block_index := leftmost_block_column + leftmost_row_index * 4;
			leftmost_enemies_byte := block_enemies[leftmost_block_index];
			// Column-based indexing: check left to right
			if (leftmost_enemies_byte & $03) <> 0 then  // bits 0,1 set (left column: enemies 0,1)
			begin
				leftmost_result_offset := leftmost_block_column * 54;
				leftmost_found_flag := 1;
			end
			else if (leftmost_enemies_byte & $0C) <> 0 then  // bits 2,3 set (middle column: enemies 2,3)
			begin
				leftmost_result_offset := leftmost_block_column * 54 + 18;
				leftmost_found_flag := 1;
			end
			else if (leftmost_enemies_byte & $30) <> 0 then  // bits 4,5 set (right column: enemies 4,5)
			begin
				leftmost_result_offset := leftmost_block_column * 54 + 36;
				leftmost_found_flag := 1;
			end;
			inc(leftmost_row_index);
		end;
		// Exit if found or if we've checked column 3
		if (leftmost_found_flag = 1 or leftmost_block_column = 3) then
			leftmost_column_loop_done := 1
		else
			inc(leftmost_block_column);
	end;
	GetLeftmostEnemyOffset := leftmost_result_offset;
end;

// Returns the Y pixel coordinate of the bottom edge of the lowest alive enemy.
// Scans monster rows bottom-to-top; byte underflow (dec past 0 -> 255) exits the loop naturally.
// Used to clamp formation drops so enemies never reach the player.
function GetLowestEnemyBottomY() : byte;
var
	gleby_r : byte;
	gleby_b : byte;
	gleby_found : byte;
	gleby_lowest_row : byte;
	gleby_row_offset : byte;
	gleby_has_bottom_enemy : byte;
	gleby_bottom_in_sprite : byte;
	gleby_result : byte;
begin
	gleby_found := 0;
	gleby_lowest_row := 0;
	gleby_r := 2;
	// Scan from bottom row (2) upward; dec past 0 wraps to 255 which exits 'r <= 2'
	while (gleby_r <= 2 and gleby_found = 0) do
	begin
		gleby_b := 0;
		while (gleby_b <= 3 and gleby_found = 0) do
		begin
			if block_enemies[gleby_r * 4 + gleby_b] <> 0 then
			begin
				gleby_lowest_row := gleby_r;
				gleby_found := 1;
			end;
			inc(gleby_b);
		end;
		if gleby_found = 0 then
			dec(gleby_r);  // at r=0 wraps to 255, exiting the while
	end;

	// Row Y offsets: row 0 = 0, row 1 = MONSTER_ROW_OFFSET, row 2 = 52
	if gleby_lowest_row = 0 then
		gleby_row_offset := 0
	else if gleby_lowest_row = 1 then
		gleby_row_offset := MONSTER_ROW_OFFSET
	else
		gleby_row_offset := 52;

	// Check whether any 'bottom' enemy (odd index; bits 1,3,5 = mask $2A) is alive in this row.
	// Bottom enemies occupy sprite pixel rows 13-20 (bottom pixel offset = 20).
	// Top-only enemies occupy rows 0-7 (bottom pixel offset = 7).
	gleby_has_bottom_enemy := 0;
	gleby_b := 0;
	while gleby_b <= 3 do
	begin
		if (block_enemies[gleby_lowest_row * 4 + gleby_b] & $2A) <> 0 then
			gleby_has_bottom_enemy := 1;
		inc(gleby_b);
	end;

	if gleby_has_bottom_enemy <> 0 then
		gleby_bottom_in_sprite := 20
	else
		gleby_bottom_in_sprite := 7;

	gleby_result := monster_base_y + gleby_row_offset + gleby_bottom_in_sprite;
	GetLowestEnemyBottomY := gleby_result;
end;



procedure UpdateTick();
var
	const USE_SPEED_TABLE   : byte = 0; // 1 = table lookup, 0 = pure linear (arcade-accurate)
	const ENABLE_DROP_FLOOR : byte = 1; // 1 = prevent formation from dropping into player
	const MONSTER_DROP_AMOUNT : byte = 6; // pixels to drop per direction change
	should_move_enemy : byte;
	enemy_count_diff : byte;
	right_edge : byte;
	left_edge : byte;
	prev_direction : byte;
begin
	// Drain deferred edge rescan from the previous kill frame.
	// Running here means the cached values are fresh before right_edge/left_edge are read below.
	if pending_edge_rescan <> 0 then
	begin
		cached_rightmost_offset := GetRightmostEnemyOffset();
		cached_leftmost_offset  := GetLeftmostEnemyOffset();
		pending_edge_rescan := 0;
	end;

	enemy_count_diff := INITIAL_INVADER_COUNT - numberOfEnemies;
	should_move_enemy := 0;

		if enemyMoveCounter <> 0 then
		begin
			dec(enemyMoveCounter);
			// Premove: fires 2 frames before the main tick to smooth out the
			// direction-change transition. Suppressed when delay <= 2 because
			// at that speed premove can't fire before the main tick.
			if enemyMoveCounter = 2 then
				if current_speed_delay > 2 then
					should_move_enemy := 1;
		end
		else begin
			// Reload delay.
			// USE_SPEED_TABLE=1: table lookup capped to linear (gentle staircase boost).
			// USE_SPEED_TABLE=0: pure linear (delay = aliens alive, arcade-accurate).
			if USE_SPEED_TABLE <> 0 then
			begin
				current_speed_delay := Helpers::GetArcadeSpeedDelay(enemy_count_diff);
				if enemy_count_diff < current_speed_delay then
					current_speed_delay := enemy_count_diff;
			end
			else
				current_speed_delay := enemy_count_diff;
			enemyMoveCounter := current_speed_delay;

			monster_animation_frame := monster_animation_frame xor 1;
			// Note: AnimateMonsters is NOT called here. All three rows are handled
			// exclusively in their respective raster IRQs (Row1/2/3), which fire
			// after the beam has passed UFO_Y but before each enemy row is scanned.
			// This keeps sprite 1's image pointer owned solely by ShowUFO() until
			// Row1 takes over, eliminating the UFO flash.

			should_move_enemy := 1;
		end;

		if should_move_enemy <> 0 then
		begin
			// Read cached edge offsets — updated in ClearMonster, so O(1) cost here
			// every tick regardless of enemy count.
			right_edge := monster_base_x + cached_rightmost_offset + 10;  // +10 for double-width enemy
			left_edge := monster_base_x + cached_leftmost_offset;

			prev_direction := enemy_direction;
			if right_edge >= 242 then
				enemy_direction := 0
			else if left_edge <= 36 then  // 47 = 36 + BULLET_X_CONTACT_REACH; ensures cbcc_block_x >= 11 for leftmost survivors
				enemy_direction := 1;

			// If direction changed, drop instead of moving horizontally this tick.
			// This keeps movement flow clean: one tick = one action (drop OR move, never both).
			if prev_direction <> enemy_direction then
			begin
				if ((ENABLE_DROP_FLOOR = 0) or (GetLowestEnemyBottomY() < player_sprite_y - MONSTER_DROP_AMOUNT)) then
					monster_base_y := monster_base_y + MONSTER_DROP_AMOUNT;
			end
			else begin
				// No direction change: move horizontally.
				// When premove is suppressed (delay <= 2), the main tick must move
				// 2px to maintain the arcade's 2px-per-cycle rate.
				if current_speed_delay <= 2 then
				begin
					if enemy_direction <> 0 then
						monster_base_x := monster_base_x + 2
					else
						monster_base_x := monster_base_x - 2;
				end
				else begin
					if enemy_direction <> 0 then
						inc(monster_base_x)
					else
						dec(monster_base_x);
				end;
			end;
			// Signal contact-erosion check: run once per march step, not per frame.
			enemy_march_tick := 1;
		end;
end;



procedure MakeMonsters();
var
	monster_sprite_color : byte = cyan;
	lm_level  : byte;  // counter for level loop
	lm_offset : byte;  // accumulated Y offset for current level

begin
	// Compute starting Y: level 1 = LEVEL_START_Y, each level adds LEVEL_Y_STEP.
	// Loop avoids a runtime multiply (max 8 iterations).
	lm_offset := 0;
	lm_level  := 1;
	while lm_level < current_level do
	begin
		lm_offset := lm_offset + LEVEL_Y_STEP;
		inc(lm_level);
	end;
	monster_base_y := LEVEL_START_Y + lm_offset;
	monster_base_x := 18;
	// Reset row-present cache for new game.
	row_has_monsters[0] := 1;
	row_has_monsters[1] := 1;
	row_has_monsters[2] := 1;
	// Sync cached edges with the formation state after pre-clearing.
	cached_rightmost_offset := GetRightmostEnemyOffset();
	cached_leftmost_offset := GetLeftmostEnemyOffset();
	
	sprite_color[useSprite]:= monster_sprite_color;
	
	// Set sprite colors
	sprite_color[monsterSprite1]:= monster_sprite_color;
	sprite_color[monsterSprite2]:= monster_sprite_color;
	sprite_color[monsterSprite3]:= monster_sprite_color;
	sprite_color[monsterSprite4]:= monster_sprite_color;
	  
	// Enable all monster sprites
	//togglebit(sprite_bitmask,monsterSprite1,1);
	//togglebit(sprite_bitmask,monsterSprite2,1);
	//togglebit(sprite_bitmask,monsterSprite3,1);
	//togglebit(sprite_bitmask,monsterSprite4,1);
	
	// Enable sprite stretching for wider monsters
	togglebit(SPRITE_STRETCH_X,monsterSprite1,1);
	togglebit(SPRITE_STRETCH_X,monsterSprite2,1);
	togglebit(SPRITE_STRETCH_X,monsterSprite3,1);
	togglebit(SPRITE_STRETCH_X,monsterSprite4,1);

	// Enable UFO bullet sprites
	sprite_color[ES_SHOT_SPRITE1]:=cyan;
	//togglebit(sprite_bitmask,ES_SHOT_SPRITE1,1);
	sprite_color[ES_SHOT_SPRITE2]:=cyan;
	//togglebit(sprite_bitmask,ES_SHOT_SPRITE2,1);
	sprite_color[ES_SHOT_SPRITE3]:=cyan;
	//togglebit(sprite_bitmask,ES_SHOT_SPRITE3,1);
end;

// ---------------------------------------------------------------------------------------------------------------------------------
// RASTER INTERRUPT HANDLERS — Scheduled chain manages all game logic timing
// ---------------------------------------------------------------------------------------------------------------------------------
// Architecture:
//
// Full game chain (normal play):
//   MainRasterPlayer (raster 0):    Updates sprite positions; schedules Starfield
//   MainRasterStarfield (raster 0): Updates starfield sprite; schedules Row3
//   MainRasterRow3 (row 2 monsters): Animates/positions row 2; schedules Row2 or Player
//   MainRasterRow2 (row 1 monsters): Animates/positions row 1; schedules Row1 or Player
//   MainRasterRow1 (row 0 monsters): Animates/positions row 0; schedules MainRasterChain
//   MainRasterChain (raster 53):     Main game logic (physics, collisions, UI)
//
// Intermission chain (get-ready screen):
//   IntermissionChain (raster 0):    Music playback, button polling; schedules Starfield
//   IntermissionStarfield (raster 0): Starfield animation; loops back to IntermissionChain
//
// Raster Mux: Sprites 1-4 repurposed per row context (enemy formation display)
// Forward Declarations: MainRasterChain (scheduled by both Player and Row1)
// ---------------------------------------------------------------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// INTERMISSION RASTER CHAIN
// ---------------------------------------------------------------------------
// Simplified raster chain for get-ready screen: only music, starfield, and input.
// No monster logic, no collision detection, no sprite updates.
// ---------------------------------------------------------------------------

interrupt IntermissionChain();
begin
	StartIRQ(0);
	
	// Flush deferred palette update before advancing the SID engine.
	// Running at I=1 here (inside interrupt) — immune to the SID play routine
	// corrupting ZP $24 (StarField_color_mem).  Clear the flag first so a
	// concurrently-written pending_palette := 1 from LevelAdvance() is never lost.
	if pending_palette = 1 then
	begin
		pending_palette := 0;
		StarField::SetStarfieldColors(pal_col1, pal_col2, pal_col3, pal_col4, pal_col5, pal_col6);		
		// Show get-ready text (uses ZP $24/$68 for sgrt_ptr / sgrt_color_ptr).
		ShowGetReadyText();
	end;	

	// Play music during intermission
	if DEBUG_ENABLE = 0 then
		call(sidfile_1_play);
			
	
	
	// Check fire button to start the level (debounced)
	Joystick(joystickPort);
	if joystickbutton = 1 then
	begin
		if (get_ready_prev_fire = 0 and level_advance_ready = 1) then
		begin			
			LevelStart();  // Exits intermission, switches to full game chain
			get_ready_prev_fire := 1;
		end;
	end
	else
		get_ready_prev_fire := 0;
	
	// Schedule next step based on current mode.
	// If LevelStart() just ran, get_ready_mode is now 0 and we must not overwrite
	// the game-chain handoff with another intermission IRQ.
	if get_ready_mode = 1 then
		RasterIRQ(IntermissionStarfield(), 250, 0)
	else
		RasterIRQ(MainRasterChain(), 0, 0);
		//RasterIRQ(MainRasterRow1(), monster_base_y - 8, 0);
		
	
	CloseIRQ();
end;

interrupt IntermissionStarfield();
begin
	StartIRQ(0);
	
	
	
	// Animate starfield
	inc(StarField_RasterCount);
	StarField::DoStarfield();
	
	// Loop back to intermission chain for next frame
	RasterIRQ(IntermissionChain(), 0, 0);
	
	CloseIRQ();
end;

// ---------------------------------------------------------------------------
// MAIN GAME RASTER CHAIN
// ---------------------------------------------------------------------------
// Full raster chain for active gameplay.
// Order: Player → Starfield → Row3 → Row2 → Row1 → Chain
//   Only MainRasterChain needs a forward declaration (Player + Starfield schedule it).
//   Each Row handler only schedules already-defined interrupts (Row3→Player,
//   Row2→Row3/Player, Row1→Row2/Row3/Player). Chain schedules all four, all defined above.
// ---------------------------------------------------------------------------

interrupt MainRasterPlayer();
begin	
		
	UpdateSprite();
	if DEBUG_ENABLE = 1 then
		SCREEN_BG_COL := BLACK;
		
	StartIRQ(0);

	// Schedule MainRasterChain FIRST — same logic as the RasterIRQ-before-heavy-work
	// pattern in MainRasterChain.  CheckBulletCollision (kill frame), UpdateTick
	// (edge-rescan frame), and DoStarfield can all overrun.  If the latch is written
	// after line 0 has passed the beam we lose a full frame on the chain.
	RasterIRQ(MainRasterChain(), 0, 0);

	// Run game logic unconditionally — intermission uses separate chain
	CheckShieldCollision();	
	UpdateTick();
	
	// Check collisions AFTER all sprite rows have been displayed
	// Only check when bullet is actively moving (not exploding)
	if player_bullet_active = 1 then
	begin
		CheckBulletCollision();
	end;	

	
	
	//asm(" lda $D01E");
	//asm(" lda $D01F");
	//border_debug_color := peek($D01E, 0);
	//SCREEN_BG_COL := border_debug_color;
			
	//SCREEN_BG_COL := border_debug_color;
	
	// Switch sprite 0 from bullet back to player
	SetSpriteLoc(useSprite, @spriteLoc/64, useBank);  // Player sprite data
	SpritePos(player_sprite_x, player_sprite_y, useSprite);  // Player position

	//togglebit(sprite_bitmask, useSprite, 1);  // Ensure sprite is enabled for player

	//RasterIRQ(MainRasterStarfield(),253,@useKernal);
	
	//border_debug_color := peek($D01E, 0);
	//SCREEN_BG_COL := border_debug_color;
	//DisplayScore();
	inc(StarField_RasterCount);
	
	StarField::DoStarfield();	
	//poke(^$D019, 0, 0);  	
	
	CloseIRQ();
end;

interrupt MainRasterStarfield();
begin	
		
	//border_debug_color := peek($D01E, 0);
	//SCREEN_BG_COL := border_debug_color;
	//DisplayScore();
	inc(StarField_RasterCount);
	StarField::DoStarfield();	
	//poke(^$D019, 0, 0);  
	
	RasterIRQ(MainRasterChain(), 0, 0);
	CloseIRQ();
end;

interrupt MainRasterRow3();
begin	
	StartIRQ(0);
	
	// Update bottom row only if it still contains monsters
	if row_has_monsters[2] <> 0 then
	begin		
		UpdateMonsters(52);  // Set screen positions for row 2
		AnimateMonsters(2); // Set image pointers for row 2
	end;

	
	RasterIRQ(MainRasterPlayer(), 222, 0);
	
	if DEBUG_ENABLE = 1 then
		SCREEN_BG_COL := GREEN;
		
	
	CloseIRQ();
end;

interrupt MainRasterRow2();
begin	
	StartIRQ(0);	

	//ShowBullet();
	
	//border_debug_color := peek(^$D01E, 0);
	//SCREEN_BG_COL := border_debug_color;
	//DisplayScore();
	

	/*if player_bullet_active <> 0 then
	begin
		ShowBullet();
		//SCREEN_BG_COL := border_debug_color;
	end;*/
	
	
	// Update middle row only if it still contains monsters
	if row_has_monsters[1] <> 0 then
	begin		
		UpdateMonsters(MONSTER_ROW_OFFSET);  // Set screen positions for row 1
		AnimateMonsters(1); // Set image pointers for row 1
	end;

	// If bottom row still has monsters, go to row3; otherwise skip to joystick handler
	if row_has_monsters[2] <> 0 then
		RasterIRQ(MainRasterRow3(), 45 + monster_base_y, 0)
	else
		RasterIRQ(MainRasterPlayer(), 222, 0);

	if DEBUG_ENABLE = 1 then
		SCREEN_BG_COL := BLUE;
	CloseIRQ();
end;

// This interrupt is triggered one time pr raster cycle
interrupt MainRasterRow1();
begin	

	StartIRQ(0);	
	togglebit(SPRITE_STRETCH_X, UFO_HW_SPRITE, 1);	
	// Update first row of monsters only if there are monsters in that row
	if row_has_monsters[0] <> 0 then
	begin		
		UpdateMonsters(0);  // Set screen positions for row 0
		AnimateMonsters(0); // Set image pointers for row 0 — also transitions sprite 1 from UFO to enemy
	end;
	
	// Choose next raster handler based on which subsequent rows still have monsters
	if row_has_monsters[1] <> 0 then
		RasterIRQ(MainRasterRow2(), 19 + monster_base_y, 0)
	else if row_has_monsters[2] <> 0 then
		RasterIRQ(MainRasterRow3(), 45 + monster_base_y, 0)
	else
		RasterIRQ(MainRasterPlayer(), 222, 0);


	if DEBUG_ENABLE = 1 then
		SCREEN_BG_COL := RED; 	
	CloseIRQ();
end;

interrupt MainRasterChain();
begin
	
	StartIRQ(0);

	// Schedule the next raster IRQ FIRST — before the SID player, before any game logic.
	// Reason: call(sidfile_1_play) takes 1000–3000 cycles (16–50 raster lines) and varies
	// per note.  If it runs before the RasterIRQ write and the target line is already past,
	// Row1/2/3 fires a full frame late → sprites show stale positions → visible flicker.
	// All inputs (flagGotoNextLevel, row_has_monsters, monster_base_y) are stable here:
	// UpdateTick and ClearMonster ran in MainRasterPlayer, which has already completed.
	if (flagGotoNextLevel = 1) then
	begin
		flagGotoNextLevel := 0;
		LevelAdvance();
	end
	else begin
		if row_has_monsters[0] <> 0 then
			RasterIRQ(MainRasterRow1(), monster_base_y - 4, 0)
		else if row_has_monsters[1] <> 0 then
			RasterIRQ(MainRasterRow2(), 19 + monster_base_y, 0)
		else if row_has_monsters[2] <> 0 then
			RasterIRQ(MainRasterRow3(), 45 + monster_base_y, 0)
		else
			RasterIRQ(MainRasterPlayer(), 222, 0);
	end;

	if DEBUG_ENABLE = 0 then
		call(sidfile_1_play)
	else 
		SCREEN_BG_COL := BLACK;

	// Game logic runs unconditionally — intermission uses separate chain
	ShowBullet();	
		
	// Apply erosion every frame — now just a charset write, fast enough to run unconditionally.
	ApplyShieldErosion();
	
	// Position and animate the UFO BEFORE Row1 fires, so sprite 1 registers hold the
	// UFO values while the VIC-II scans through UFO_Y.
	ShowUFO();
	UpdateUFO();
	ShowUFOBullet();
	UpdateUFOBullet();
	CheckEnemyShieldCollision();
	CheckEnemyShieldContact();

	// Fire enemy shots from alien positions (column-table / player-tracking logic)
	TickEnemyShotFiring();

	

	
	//border_debug_color := peek(^$D01E, 0);
	//SCREEN_BG_COL := border_debug_color;
	//DisplayScore();
	// Clear sprite collision registers to remove garbage data
	//asm(" lda $D01E");
	//asm(" lda $D01F");

	UpdatePlayerBullet();
	
	// Update enemy shot movement/animation
	//UpdateEnemyShot();
	
	// Show enemy shot sprite if active
	//ShowEnemyShot();

	
	// Lightweight joystick update only
	//Memory::Fill(#joystickup,0,5);
	Joystick(joystickPort);
		
	// Check fire button with debounce (only fire on button press, not hold)    
	if (joystickbutton=1) then
	begin
		
		if (previous_fire_state = 0 and player_bullet_active = 0) then		
		begin
			FirePlayerBullet();
			//inc(border_debug_color);
		end;
		previous_fire_state := 1;
	end
	else
		previous_fire_state := 0;

	// Check player bullet vs UFO — must run after UpdatePlayerBullet so bullet position is current.
	CheckUFOCollision();

	// Check player bullet vs enemy bullets (shot-vs-shot collision)
	// Must run after both UpdatePlayerBullet and UpdateUFOBullet so positions are current.
	// Rolling/Teflon shot (slot 1) is immune; Plunger and Squiggly are destroyable.
	CheckShotVsShotCollision();

	
	

	
	/*if player_bullet_active <> 0 then
	begin	
		//SCREEN_BG_COL := border_debug_color;
	end;*/
		
	// Do heavy work at start of frame where we have most time
	// Increment score
	/*Score += SCORE_INCREMENT;
	if (Score >= 10000) then begin
		Score := Score - 10000;
		Score2 += 1;
	end;*/
	
	// Heavy game logic - UpdateTick may change monster_base_y (drop), but the Row
	// handlers always use the global monster_base_y when they fire, so sprites track
	// the updated position correctly even though the latch was written with the old value.
	//UpdateTick();

	CloseIRQ();
end;

// ---------------------------------------------------------------------------
// LevelAdvance
//   Called when all enemies are cleared.  Cycles current_level (1→9→1),
//   resets board/bullet/march state, and repositions the formation for
//   the new level (each level starts LEVEL_Y_STEP pixels lower).
// ---------------------------------------------------------------------------
procedure LevelAdvance();
var
	
begin
	// Increment both the display level (wraps at 9) and the persistent counter (never wraps)
	inc(current_level);
	if current_level > LEVEL_LAST then
		current_level := 1;
	inc(total_level_counter);

	// Disable all sprites during intermission; LevelStart() re-enables them when
	// the player presses fire.
	sprite_bitmask := 0;

	// -----------------------------------------------------------------------
	// All three calls below use ZP $24 / $68 for pointer variables (confirmed
	// in compiled ASM).  They MUST run here at I=1 (inside the IRQ handler)
	// so the SID play routine called from IntermissionChain every frame cannot
	// fire between pointer-low and pointer-high byte writes and corrupt them.
	// -----------------------------------------------------------------------

	// Pick starfield palette for the incoming level, repeating every 10 levels.
	// Stage the 6 colour bytes into globals and set pending_palette := 1.
	// IntermissionChain will call SetStarfieldColors at I=1 on the next frame,
	// avoiding the ZP $24 (StarField_color_mem) collision with the SID play routine.
	
	advancelevel_palette_level := total_level_counter;
	while advancelevel_palette_level > 10 do begin
		advancelevel_palette_level := advancelevel_palette_level - 10;
	end;
	if advancelevel_palette_level = 1 then begin
		pal_col1:=BLUE;   pal_col2:=PURPLE; pal_col3:=GREY;
		pal_col4:=LIGHT_GREY; pal_col5:=LIGHT_BLUE; pal_col6:=DARK_GREY;  // Purple Haze
	end
	else if advancelevel_palette_level = 2 then begin
		pal_col1:=RED;    pal_col2:=PURPLE; pal_col3:=GREY;
		pal_col4:=LIGHT_GREY; pal_col5:=LIGHT_RED;  pal_col6:=BROWN;      // Red
	end
	else if advancelevel_palette_level = 3 then begin
		pal_col1:=DARK_GREY; pal_col2:=LIGHT_BLUE; pal_col3:=GREY;
		pal_col4:=WHITE; pal_col5:=LIGHT_GREY; pal_col6:=DARK_GREY;       // Christmas
	end
	else if advancelevel_palette_level = 4 then begin
		pal_col1:=BROWN;  pal_col2:=GREEN;  pal_col3:=GREY;
		pal_col4:=LIGHT_GREY; pal_col5:=LIGHT_GREEN; pal_col6:=DARK_GREY; // Jungle Green
	end
	else if advancelevel_palette_level = 5 then begin
		pal_col1:=RED;    pal_col2:=ORANGE; pal_col3:=WHITE;
		pal_col4:=YELLOW; pal_col5:=YELLOW; pal_col6:=BROWN;              // Gold
	end
	else if advancelevel_palette_level = 6 then begin
		pal_col1:=BLUE;   pal_col2:=LIGHT_BLUE; pal_col3:=GREY;
		pal_col4:=WHITE;  pal_col5:=CYAN;   pal_col6:=DARK_GREY;          // Ice Blue
	end
	else if advancelevel_palette_level = 7 then begin
		pal_col1:=RED;    pal_col2:=ORANGE; pal_col3:=GREY;
		pal_col4:=WHITE;  pal_col5:=YELLOW; pal_col6:=BROWN;              // Lava
	end
	else if advancelevel_palette_level = 8 then begin
		pal_col1:=DARK_GREY; pal_col2:=ORANGE; pal_col3:=GREY;
		pal_col4:=WHITE; pal_col5:=LIGHT_GREY; pal_col6:=BROWN;           // Bronze
	end
	else if advancelevel_palette_level = 9 then begin
		pal_col1:=RED;    pal_col2:=PURPLE; pal_col3:=YELLOW;
		pal_col4:=WHITE;  pal_col5:=LIGHT_BLUE; pal_col6:=BLUE;           // Various
	end
	else if advancelevel_palette_level = 10 then begin
		pal_col1:=RED;    pal_col2:=GREEN;  pal_col3:=LIGHT_BLUE;
		pal_col4:=WHITE;  pal_col5:=YELLOW; pal_col6:=BLUE;               // RGB
	end;
	pending_palette := 1;

	// Restore shields — IRQ-safe: glyph copies use inline ASM (no ZP);
	// surface scan wrapped in PreventIRQ/EnableIRQ inside CopyShieldSprites.
	if total_level_counter < 50 then
		CopyShieldSprites();

	// Signal the main-context polling loop to run ReadyMonsters + MakeMonsters.
	// Those are wrapped in PreventIRQ/EnableIRQ there to protect ZP $24/$68 from
	// the SID play routine that fires every frame via IntermissionChain.
	level_advance_ready   := 0;
	level_advance_pending := 1;

	// Enter intermission mode.
	get_ready_mode := 1;
	get_ready_prev_fire := 0;

	// Install intermission raster chain — music resumes on the very next frame.
	RasterIRQ(IntermissionChain(), 0, 0);
end;



// ---------------------------------------------------------------------------------------------------------------------------------
// Main program loop. Turn CIA interrupts off, copy the character set from ROM into RAM and tell the machine to look at CharSetLoc
// for its character set, initialise the pointers and start the raster chain off.
// ---------------------------------------------------------------------------------------------------------------------------------
begin
	/*MakeSprites();
	
	InitSid(sidfile_1_init);
	DisableCIAInterrupts();
	SetMemoryConfig(1, 0, 0);
	
	SCREEN_BG_COL:=BLACK;
    SCREEN_FG_COL:=BLACK;
	
	// Clear sprite collision registers to remove garbage data
	asm(" lda $D01E");
	asm(" lda $D01F");
		
	
	StarField::CreateStarScreen();
	
	EnableRasterIrq();	
	DisplayText();
	
	// Show "Get Ready" screen for the first level before starting play.
	// AdvanceLevel will increment current_level from 0 to 1, display intermission screen,
	// and install the IntermissionChain raster handler.
	//dec(current_level);
	//dec(total_level_counter);
	
	
	// AdvanceLevel installed IntermissionChain, now safe to enable IRQs
	RasterIRQ(MainRasterChain(),0,0);
	//RasterIRQ(IntermissionChain(), 0, 0);
	
	enableirq();

	// Non-IRQ SID playback (main context). This runs once during init and is safe
	// to execute outside the raster IRQ. Comment/uncomment to test.
	//call(sidfile_1_play); // main-context playback (disabled)
	//call(sidfile_1_play); // alternative: keep commented if you prefer raster IRQ playback

	Loop();*/
	
	MakeSprites();
	
	InitSid(sidfile_1_init);
	//disableciainterrupts();
	//setmemoryconfig(1,0,0);
	
	DisableCIAInterrupts();
	
	SCREEN_BG_COL:=BLACK;
    SCREEN_FG_COL:=BLACK;
	
	// Clear sprite collision registers to remove garbage data
	//asm(" lda $D01E");
	//asm(" lda $D01F");
		
	
	StarField::CreateStarScreen();	
	/*const StarColour1 : byte = 6;   // Blue
	const StarColour2 : byte = 4;   // Purple
	const StarColour3 : byte = 12;  // Grey 
	const StarColour4 : byte = 15;  // Light_Grey
	const StarColour5 : byte = 14;  // Light Blue
	const StarColour6 : byte = 11;  // Grey Dark*/
		
	// IO area visible at $D000-$DFFF, RAM visible at $A000-$BFFF (NO BASIC) and RAM visible at $E000-$FFFF (NO KERNAL). 
	// This is the typical memory configuration for demo/game development. 
	SetMemoryConfig(1, 0, 0);

	// SEI: keep I=1 for the entire init sequence.
	// InitSid (jsr $1000) is opaque SID machine code that may call CLI internally.
	// We must ensure I=1 from here until we have a valid IRQ handler installed,
	// otherwise any raster interrupt (once armed) jumps through a garbage $FFFE/$FFFF
	// vector (Kernal is banked out, that address is uninitialized RAM) and crashes.
	//PreventIRQ();

	DisplayText();

	// Show "Get Ready" screen for the first level before starting play.
	// AdvanceLevel will increment current_level from 0 to 1 and display the intermission screen.
	dec(current_level);
	dec(total_level_counter);
	LevelAdvance();   // ← installs IntermissionChain into $FFFE/$FFFF

	// ONLY NOW arm the VIC raster IRQ hardware, and ONLY NOW open the CPU interrupt gate.
	// This order is mandatory: vector first, hardware enable second, CLI last.
	EnableRasterIrq();
	EnableIRQ();      // CLI — first raster interrupt fires safely into IntermissionChain

	// Non-IRQ SID playback (main context). This runs once during init and is safe
	// to execute outside the raster IRQ. Comment/uncomment to test.
	//call(sidfile_1_play); // main-context playback (disabled)
	//call(sidfile_1_play); // alternative: keep commented if you prefer raster IRQ playback

	//loop();
	// Main context spin-loop: raster IRQs preempt freely here, so music advances
	// every frame while MakeMonsters() is executing.
	while 1 do
	begin
		if level_advance_pending = 1 then
		begin
			level_advance_pending := 0;
			// Palette, ShowGetReadyText, and CopyShieldSprites were moved to LevelAdvance()
			// so they run at I=1 — immune to the SID play routine corrupting ZP $24/$68.
			//
			// ReadyMonsters uses inline ASM with absolute indexed addressing — no ZP
			// pointers touched, fully IRQ-safe. PreventIRQ/EnableIRQ no longer needed.
			ReadyMonsters();
			PreclearLeftmostAndBottomEnemies();
			
			// MakeMonsters uses no ZP pointer variables — runs safely with IRQs enabled.
			MakeMonsters();
			level_advance_ready := 1;  // ungate fire-to-start in IntermissionChain
		end;
		if (score_dirty = 1) then
			DisplayScore();
	end;
end.
