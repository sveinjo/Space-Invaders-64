program SpaceInvaders64;
@use "screen/screen"
@use "system/memory"
@use "system"
@use "starfield"
@use "helpers"

var
	sidfile: incsid("sid/Courier.sid",2);

	
	
	const useKernal:byte=0;
	
	
	//Score : Integer = 9950;
	//Score2 : Integer = 0;
	
	
	
	// Game constants
	const INITIAL_INVADER_COUNT : byte = 72; // Arcade has 55
	const ENEMIES_TO_CLEAR : byte = 0;  // How many enemies to clear (out of 72 total)
	const MONSTER_SPACING : byte = 54;
	const MONSTER_ROW_OFFSET : byte = 26;
	const PLAYER_MIN_X : byte = 39;
	const PLAYER_MAX_X : byte = 218;
	const PLAYER_POS_Y : byte = 226; // 213 is where I it would be if sprite is at the bottom of it's box
	//const SCORE_INCREMENT : byte = 9;
	const SPRITE_HEIGHT : byte = 21;
	//const ENEMY_COLUMN_WIDTH : byte = 16;
	//const ENEMY_HITBOX_HALF_WIDTH : byte = 8;
	//const ENEMY_HITBOX_HALF_HEIGHT : byte = 10;
	//const BULLET_HIT_PRECHECK_RADIUS : byte = 12;

	// Debug flag: set to 1 to enable debug color changes, 0 to disable
	const DEBUG_ENABLE : byte = 0;
	// Set to 1 to prevent the formation from dropping into the player; 0 to disable (useful for debugging)
	const ENABLE_DROP_FLOOR : byte = 1;
	border_debug_color : byte = 2;
	// Debug helper flag: set to 1 when DebugClearNextMonster actually cleared one
    debug_last_cleared : byte = 0;
    // Number of enemies to keep alive when auto-clearing in debug mode
	const DEBUG_KEEP_ALIVE : byte = 3;
	
	enemyMoveCounter : byte = INITIAL_INVADER_COUNT; // equals number of invaders
	enemy_direction : byte = 1;
	numberOfEnemies : byte = 0;
	const MONSTER_DROP_AMOUNT : byte = 6;
	const MONSTER_DROP_AMOUNT2 : byte = 10;
	
	const MONSTER_START_Y : byte = 102 ; // Initial monster base Y (was 71 base + 41 adjustment)

	// UFO constants
	const UFO_HW_SPRITE : byte = 1;   // Hardware sprite index — shared with monsterSprite1 via raster mux
	const UFO_SPRITE_IMG : byte = 16; // Sprite image index in the sprite binary
	const UFO_Y : byte = 44;          // Fixed Y near top of screen (must be < monster_base_y - 33)
	const UFO_X_MIN : byte = 24;      // Left edge of 29-char (232-pixel) play field
	const UFO_X_MAX : byte = 230;     // Right edge — sprite body (+24 px) lands at ~254, still in byte range

	// UFO state
	ufo_x : byte = UFO_X_MIN;           // Current X position
	ufo_direction : byte = 1;           // 1 = moving right, 0 = moving left
	ufo_move_skip_counter : byte = 0;   // Counts 0-2; move is skipped when the counter resets (every 3rd frame)

	// UFO bullets (3 staggered bullets fired in sequence)
	ufo_bullet_active : array[3] of byte = (0, 0, 0);       // 0=inactive, 1=moving, 2=exploding
	ufo_bullet_x : array[3] of byte = (0, 0, 0);           // Fixed X position (set when fired)
	ufo_bullet_y : array[3] of byte = (0, 0, 0);           // Current Y position
	ufo_bullet_anim_index : array[3] of byte = (0, 0, 0);  // Current animation frame (0-3)
	ufo_bullet_move_tick : array[3] of byte = (0, 0, 0);   // Accumulator for movement speed
	ufo_bullet_anim_tick : array[3] of byte = (0, 0, 0);   // Accumulator for animation speed
	ufo_bullet_explode_counter : array[3] of byte = (0, 0, 0); // Frames remaining in explosion
	ufo_bullet_sprite : array[3] of byte = (6, 5, 7);      // Hardware sprite indices
	ufo_bullet_anim_start : array[3] of byte = (13, 9, 5); // Animation frame start offsets

	ufo_bullet_stagger_counter : byte = 0;  // Countdown to fire next bullet
	ufo_bullet_next_to_fire : byte = 0;     // Which bullet fires next (0-2)

	sequential_clear_counter : byte = 71; // Sequential enemy clearing counter, starts at 71 (last enemy index)
	
	//pos_x : byte = PLAYER_MIN_X;
	

	// Player bullet variables
	player_bullet_active : byte = 0;  // 0 = inactive, 1 = active, 2 = exploding
	player_bullet_x : byte;
	player_bullet_y : byte;
	explosion_frame_counter : byte = 0;  // Counts frames for explosion animation
	previous_fire_state : byte = 0;  // Track previous fire button state for debounce
	const BULLET_SPEED : byte = 4;  // Pixels per frame
	//const BULLET_SPRITE_HEIGHT : byte = 21;  // Standard C64 sprite height
	const EXPLOSION_DURATION : byte = 16;  // Frames to show explosion
	// --- Hitbox / explosion tuning ---
	// Explosion sprite X alignment: subtracted from block_x + col*18 (increase = moves left)
	const EXPLOSION_X_OFFSET : byte = 6;
	// Explosion sprite Y alignment: added to block_y + row*14 (increase = moves down)
	const EXPLOSION_Y_OFFSET : byte = 0;
	// Number of pixels from the TOP of the sprite box to where the explosion lit pixels begin.
	// Set to (SPRITE_HEIGHT - pixel_height) when pixels are packed at the bottom of the sprite frame,
	// so the snap calculation places the box above the enemy and the pixels land on it visually.
	// Must match the actual sprite pixel layout in the .flf sheet.
	const EXPLOSION_PIXELS_FROM_TOP : byte = 13;
	// How many pixels below the enemy's bottom edge the bullet still registers a hit (increase = fires sooner)
	const BULLET_Y_CONTACT_REACH : byte = 0;
	// Distance from the top of the bullet sprite box to the actual contact pixels (bullet pixels are at the bottom)
	// C64 sprite box is 21px tall; 4px contact strip at bottom => offset = 21 - 4 = 17
	const BULLET_Y_CONTACT_OFFSET : byte = 13;
	// How many pixels into the bullet sprite the contact point is (increase = aim further right to hit)
	const BULLET_X_CONTACT_REACH : byte = 11;

							
  
	// sprite_x is usually an integer since x values range between 
	// 0 and 320. But we have a smaller play area.
	player_sprite_x : byte = PLAYER_MIN_X;
	player_sprite_y : byte = PLAYER_POS_Y;
	
	monster_base_x : byte;
	monster_base_y : byte;
	// Cached formation edge offsets (pixel offset from monster_base_x).
	// Updated in ClearMonster whenever an enemy dies. Read-only in UpdateTick.
	cached_rightmost_offset : byte = 198; // 3*54+36 = full formation default
	cached_leftmost_offset : byte = 0;   // leftmost enemy at offset 0
	
	// Track which enemies are alive in each block (12 blocks, 6 enemies per block)
	// Each bit 0-5 represents an enemy: bit set = alive, bit clear = dead
	// Note: blocks are stored row-major with row 0 = TOP, row 2 = BOTTOM
	block_enemies : array[12] of byte = (
		$3F, $3F, $3F, $3F,  // Row 0 blocks (top): all 6 enemies alive
		$3F, $3F, $3F, $3F,  // Row 1 blocks
		$3F, $3F, $3F, $3F   // Row 2 blocks (bottom)
	);
	
	const monsterSprite1:byte = 1;
	const monsterSprite2:byte = 2;
	const monsterSprite3:byte = 3;
	const monsterSprite4:byte = 4;
	
	// joystick_dir is used to display either left or right-pointing sprite
	player_joystick_direction : byte;
	// monster_animation_frame controls monster sprite animation independently
	monster_animation_frame : byte;
	// sprite location is where we keep the sprite in the memory.
	// also used for setspriteloc that needs this value divided by 64
	@define spriteLoc $2000
	// In this tuturial, we use sprite "0" as the default one
	const useSprite:byte = 0;
	// Use joystick port 2
	const joystickPort: byte = 2;
	const useBank:byte = 0;
	// Include the sprite binary file. The original 
	// image is located under sprites/sprites.flf 
		
	// Export all sprites automatically on each build
	@export "sprites/spritesheet.flf" "sprites/spritesheet.bin" 1664 	  	
	sprites:incbin("sprites/spritesheet.bin", @spriteLoc); 
	

	

	// Enemy-shot globals (prefixed es_ to avoid global namespace collisions)
	// Support 3 simultaneous hardware-shot slots with staggered firing
	es_shot_active : array[3] of byte = (0,0,0); // 0=inactive,1=moving,2=exploding
	es_shot_x : array[3] of byte = (0,0,0);
	es_shot_y : array[3] of byte = (0,0,0);  // screen Y position while moving (state 1)
	es_shot_anim_index : array[3] of byte = (0,0,0);
	// Single shared movement tick — all shots advance together each tick.
	es_move_tick : byte = 0;
	// Single shared animation tick — controls when anim frame advances.
	es_anim_tick : byte = 0;
	// Per-shot explosion counter to track individual explosion duration
	es_explode_counter : array[3] of byte = (0, 0, 0);

	// Sequence/stagger scheduler
	es_shot_sequence_active : byte = 0; // 0 = idle, 1 = firing sequence active
	es_shot_next_to_fire : byte = 0; // 0..2 index of next shot to spawn
	es_shot_stagger_counter : byte = 0; // countdown frames between staggered shots

	// simple PRNG seed for enemy-shot X generation
	es_rand_seed : byte = $55;
	
	// Shot sprite hardware indices (use remaining hardware sprites).
	// Stored as a lookup array so ShowEnemyShot can index by slot without if/else.
	const ES_SHOT_SPRITE1:byte = 6;
	const ES_SHOT_SPRITE2:byte = 5;
	const ES_SHOT_SPRITE3:byte = 7;
	es_shot_sprite_num : array[3] of byte = (6, 5, 7); // matches SPRITE1/2/3 order

	const ES_SHOT_ANIM_START:byte = 13; // image indices 5..8
	const ES_SHOT_ANIM_FRAMES:byte = 4;
	const ES_SHOT_MOVE_FRAMES:byte = 3;   // every Nth frame an extra pixel is added to movement
	const ES_SHOT_ANIM_HOLD_FRAMES:byte = 3; // frames each animation image is shown before advancing
	const ES_SHOT_EXPLODE_DURATION:byte = 10; // frames enemy-shot explosion stays on screen
	const ES_SHOT_STAGGER_FRAMES:byte = 50; // ~1 second at 50Hz
	const UFO_BULLET_STAGGER_FRAMES:byte = 50; // frames between UFO bullet fires
	interrupt MainRasterRow2();
	interrupt MainRasterRow3();
	interrupt MainRasterJoystick();
	interrupt MainRasterPlayer();
	interrupt MainRasterStarfield();
	
	// Declarations (commented out where no longer needed)
	interrupt MainRasterRow1();
	function GetRightmostEnemyOffset() : byte;
	function GetLeftmostEnemyOffset() : byte;
	//procedure ClearMonster(blockIndex: byte; enemyIndex: byte);
	//procedure AnimateMonsters(enemyRow: byte);
	//procedure UpdateMonsters(rowOffset: byte);
	//procedure FirePlayerBullet();
	//procedure UpdatePlayerBullet();
	//procedure CheckBulletCollision();
	//procedure ShowBullet();
	//Procedure DisplayScore();
	//Procedure DebugBorder();


// ---------------------------------------------------------------------------
// UFO procedures — sprite 2 is set here (top of frame, raster 0 context)
// and later repurposed by MainRasterRow1/2/3 for enemy sprites.
// ---------------------------------------------------------------------------

procedure ShowUFO();
begin
	SetSpriteLoc(UFO_HW_SPRITE, @spriteLoc/64 + UFO_SPRITE_IMG, useBank);
	SpritePos(ufo_x, UFO_Y, UFO_HW_SPRITE);
	togglebit(SPRITE_STRETCH_X, UFO_HW_SPRITE, 0);
	
end;

procedure UpdateUFO();
begin
	// Advance skip counter; every 3rd frame the move is skipped.
	ufo_move_skip_counter := ufo_move_skip_counter + 1;
	if ufo_move_skip_counter >= 3 then
	begin
		ufo_move_skip_counter := 0;
		// Skip movement this frame (counter rolled over).
	end
	else
	begin
		if ufo_direction <> 0 then
		begin
			// Moving right — bounce at right edge
			if ufo_x >= UFO_X_MAX then
				ufo_direction := 0
			else
				inc(ufo_x);
		end
		else
		begin
			// Moving left — bounce at left edge
			if ufo_x <= UFO_X_MIN then
				ufo_direction := 1
			else
				dec(ufo_x);
		end;
	end;
end;

procedure FireUFOBullet(bullet_index: byte);
begin
	ufo_bullet_active[bullet_index] := 1;
	ufo_bullet_x[bullet_index] := ufo_x;    // Fire from current UFO position
	ufo_bullet_y[bullet_index] := UFO_Y + 8; // Start just below UFO
	ufo_bullet_anim_index[bullet_index] := 0;
	ufo_bullet_move_tick[bullet_index] := 0;
	ufo_bullet_anim_tick[bullet_index] := 0;
end;

procedure ShowUFOBullet();
var
	sub_i : byte;
	ub_sprite_index : byte;
	ub_sprite : byte;
begin
	sub_i := 0;
	while sub_i <= 2 do
	begin
		if ufo_bullet_active[sub_i] <> 0 then
		begin
			ub_sprite := ufo_bullet_sprite[sub_i];
			if ufo_bullet_active[sub_i] = 1 then
				ub_sprite_index := ufo_bullet_anim_start[sub_i] + ufo_bullet_anim_index[sub_i]
			else
				ub_sprite_index := 4;  // Explosion frame

			SetSpriteLoc(ub_sprite, @spriteLoc/64 + ub_sprite_index - 1, useBank);
			SpritePos(ufo_bullet_x[sub_i], ufo_bullet_y[sub_i], ub_sprite);
		end;
		inc(sub_i);
	end;
end;

procedure UpdateUFOBullet();
var
	ub_i : byte;
	ub_move_fired : byte;
	ub_anim_fired : byte;
begin
	ub_i := 0;
	while ub_i <= 2 do
	begin
		if ufo_bullet_active[ub_i] <> 0 then
		begin
			// Movement tick: fires every ES_SHOT_MOVE_FRAMES frames (3)
			ub_move_fired := 0;
			inc(ufo_bullet_move_tick[ub_i]);
			if ufo_bullet_move_tick[ub_i] >= ES_SHOT_MOVE_FRAMES then
			begin
				ufo_bullet_move_tick[ub_i] := 0;
				ub_move_fired := 1;
			end;

			// Animation tick: fires every ES_SHOT_ANIM_HOLD_FRAMES frames (3)
			ub_anim_fired := 0;
			inc(ufo_bullet_anim_tick[ub_i]);
			if ufo_bullet_anim_tick[ub_i] >= ES_SHOT_ANIM_HOLD_FRAMES then
			begin
				ufo_bullet_anim_tick[ub_i] := 0;
				ub_anim_fired := 1;
			end;

			if ufo_bullet_active[ub_i] = 1 then
			begin
				// 1px every frame; +1 bonus pixel on movement tick
				ufo_bullet_y[ub_i] := ufo_bullet_y[ub_i] + 1;
				if ub_move_fired <> 0 then
					ufo_bullet_y[ub_i] := ufo_bullet_y[ub_i] + 1;

				// Animation advances on its own tick
				if ub_anim_fired <> 0 then
					ufo_bullet_anim_index[ub_i] := (ufo_bullet_anim_index[ub_i] + 1) & (ES_SHOT_ANIM_FRAMES - 1);

				// Check if hit bottom of screen
				if ufo_bullet_y[ub_i] >= (249 - SPRITE_HEIGHT) then
				begin
					ufo_bullet_active[ub_i] := 2;
					ufo_bullet_explode_counter[ub_i] := 0;
				end;
			end
			else if ufo_bullet_active[ub_i] = 2 then
			begin
				// Explosion frame
				inc(ufo_bullet_explode_counter[ub_i]);
				if ufo_bullet_explode_counter[ub_i] >= ES_SHOT_EXPLODE_DURATION then
					ufo_bullet_active[ub_i] := 0;
			end;
		end;
		inc(ub_i);
	end;
end;

procedure ClearMonster(blockIndex: byte; enemyIndex: byte);
var
	sprite_data_ptr : ^byte;
	frame1_sprite_index : byte;
	frame2_sprite_index : byte;
	sprite_offset_start : byte;
	enemy_horizontal_offset : byte;
	enemy_vertical_offset : byte;
	sprite_base_address : integer;
	enemy_mask : byte;
	was_alive : byte;
Begin
	// Calculate sprite indices for both animation frames
	// Each block has 2 sprites (animation frames)
	// Block 0 = sprites 26-27, Block 1 = sprites 28-29, etc.
	frame1_sprite_index := 26 + (blockIndex << 1);  // First animation frame
	frame2_sprite_index := frame1_sprite_index + 1;  // Second animation frame
    
	// Each block contains 6 enemies in a 3x2 grid (column-based indexing):
	// Column 0: Enemy 0(top), 1(bottom)
	// Column 1: Enemy 2(top), 3(bottom)
	// Column 2: Enemy 4(top), 5(bottom)
	// Each enemy is 5 pixels wide × 8 pixels tall
    
	// Calculate horizontal offset - which byte column (0, 1, or 2)
	// Enemy index: 0,1=col0, 2,3=col1, 4,5=col2
	enemy_horizontal_offset := enemyIndex >> 1;  // Divide by 2 to get column
    
	// Calculate vertical offset
	// Even indices (0,2,4): top row at offset 0
	// Odd indices (1,3,5): bottom row at offset 13 rows
	if (enemyIndex & 1) <> 0 then
		enemy_vertical_offset := 39  // 13 rows * 3 bytes = 39
	else
		enemy_vertical_offset := 0;
    
	// Total offset within the 64-byte sprite
	sprite_offset_start := enemy_horizontal_offset + enemy_vertical_offset;
    
	// Clear first animation frame (8 pixel rows)
	sprite_base_address := frame1_sprite_index;
	sprite_base_address := sprite_base_address << 6;  // * 64
	sprite_data_ptr := @spriteLoc + sprite_base_address + sprite_offset_start;
    
	// Unrolled loop for 8 pixel rows - faster than loop overhead
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
    
	// Clear second animation frame (8 pixel rows)
	sprite_base_address := frame2_sprite_index;
	sprite_base_address := sprite_base_address << 6;  // * 64
	sprite_data_ptr := @spriteLoc + sprite_base_address + sprite_offset_start;
    
	// Unrolled loop for 8 pixel rows
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
	sprite_data_ptr := sprite_data_ptr + 3;
	sprite_data_ptr^ := 0;
    
	// Speed up as enemies decrease
	// Update block_enemies bitmask for this enemy and increment cleared count
	enemy_mask := 1 << enemyIndex;
	was_alive := (block_enemies[blockIndex] & enemy_mask) <> 0;
	if was_alive <> 0 then
	begin
		block_enemies[blockIndex] := block_enemies[blockIndex] & (enemy_mask xor $FF);
		if (numberOfEnemies < INITIAL_INVADER_COUNT) then
			inc(numberOfEnemies);
		// Refresh cached edge offsets so UpdateTick always reads a valid value
		// without scanning every frame. Cost is one scan per kill event only.
		cached_rightmost_offset := GetRightmostEnemyOffset();
		cached_leftmost_offset := GetLeftmostEnemyOffset();
	end;
end;

procedure AnimateMonsters(enemyRow: byte);
var
	sprite_ptr_base: byte;
	current_sprite_ptr: byte;
begin
	// Calculate the base sprite pointer once for this row
	// Row 0: blocks 0-3 (sprites 26-33)
	// Row 1: blocks 4-7 (sprites 34-41)
	// Row 2: blocks 8-11 (sprites 42-49)
	sprite_ptr_base := @spriteLoc/64 + 26 + (enemyRow << 3) + monster_animation_frame;
    
	// Set sprite locations using pre-calculated base + incremental additions
	current_sprite_ptr := sprite_ptr_base;
	SetSpriteLoc(monsterSprite1, current_sprite_ptr, useBank);
    
	current_sprite_ptr := current_sprite_ptr + 2;
	SetSpriteLoc(monsterSprite2, current_sprite_ptr, useBank);
    
	current_sprite_ptr := current_sprite_ptr + 2;
	SetSpriteLoc(monsterSprite3, current_sprite_ptr, useBank);
    
	current_sprite_ptr := current_sprite_ptr + 2;
	SetSpriteLoc(monsterSprite4, current_sprite_ptr, useBank);
end;

procedure UpdateMonsters(rowOffset: byte);
var
	y_position: byte;
	x_position: byte;
begin
	// Pre-calculate Y position to avoid repeated additions
	y_position := monster_base_y + rowOffset;
    
	// Update sprites using incremental X positions instead of multiplications
	x_position := monster_base_x;
	SpritePos(x_position, y_position, monsterSprite1);
    
	x_position := x_position + MONSTER_SPACING;
	SpritePos(x_position, y_position, monsterSprite2);
    
	x_position := x_position + MONSTER_SPACING;
	SpritePos(x_position, y_position, monsterSprite3);
    
	x_position := x_position + MONSTER_SPACING;
	SpritePos(x_position, y_position, monsterSprite4);
end;
	

procedure DebugClearNextMonster();
var
	block_idx: byte;
	enemy_idx: byte;
	found_flag: byte;
	emask: byte;
begin
	debug_last_cleared := 0;
	// Do not auto-clear when remaining enemies are at or below DEBUG_KEEP_ALIVE
	if (INITIAL_INVADER_COUNT - numberOfEnemies) <= DEBUG_KEEP_ALIVE then
	begin
		// nothing to do
	end
	else
	begin
		found_flag := 0;
		block_idx := 0;
	while (block_idx <= 11 and found_flag = 0) do
	begin
		enemy_idx := 0;
		while (enemy_idx <= 5 and found_flag = 0) do
		begin
			emask := 1 << enemy_idx;
			if (block_enemies[block_idx] & emask) <> 0 then
			begin
				ClearMonster(block_idx, enemy_idx);
				debug_last_cleared := 1;
				found_flag := 1;
			end;
			inc(enemy_idx);
		end;
		inc(block_idx);
	end;
	end;
end;

	
procedure MakeSprites();
begin	
	// Set common sprite multicolor registers
	//sprite_multicolor_reg1:=green;
	//sprite_multicolor_reg2:=white;
	// Set sprite "0" individual color value 
	sprite_color[useSprite]:=light_blue;
	// Turn on sprite 0 (or @useSprite)
	togglebit(sprite_bitmask,useSprite,1);
	// Enable enemy-shot hardware sprites and set color
	sprite_color[ES_SHOT_SPRITE1]:=cyan;
	sprite_color[ES_SHOT_SPRITE2]:=cyan;
	sprite_color[ES_SHOT_SPRITE3]:=cyan;
	togglebit(sprite_bitmask,ES_SHOT_SPRITE1,1);
	togglebit(sprite_bitmask,ES_SHOT_SPRITE2,1);
	togglebit(sprite_bitmask,ES_SHOT_SPRITE3,1);
	// UFO uses hardware sprite 2 (shared with monsterSprite2 via raster mux).
	// The sprite is already enabled by MakeMonsters via monsterSprite2, but set
	// its color here so it is distinct at the top of the screen.
	//sprite_color[UFO_HW_SPRITE] := light_red;
end;


// Clears all enemies in the leftmost column and bottom row
procedure PreclearLeftmostAndBottomEnemies();
begin
	ClearMonster(0, 0);
	ClearMonster(0, 1);
	ClearMonster(4, 0);
	ClearMonster(4, 1);
	ClearMonster(8, 0);
	ClearMonster(8, 1);
	
	ClearMonster(8, 3);
	ClearMonster(8, 5);	
	ClearMonster(9, 1);
	ClearMonster(9, 3);
	ClearMonster(9, 5);
	ClearMonster(10, 1);
	ClearMonster(10, 3);
	ClearMonster(10, 5);
	ClearMonster(11, 1);
	ClearMonster(11, 3);
	ClearMonster(11, 5);
	
	/*ClearMonster(8, 2);
	ClearMonster(8, 4);	
	ClearMonster(9, 0);
	ClearMonster(9, 2);
	ClearMonster(9, 4);
	ClearMonster(10, 0);
	ClearMonster(10, 2);
	ClearMonster(10, 4);
	ClearMonster(11, 0);
	ClearMonster(11, 2);
	ClearMonster(11, 4);
	
	ClearMonster(4, 2);
	ClearMonster(4, 4);	
	ClearMonster(5, 0);
	ClearMonster(5, 2);
	ClearMonster(5, 4);
	ClearMonster(6, 0);
	ClearMonster(6, 2);
	ClearMonster(6, 4);
	ClearMonster(7, 0);
	ClearMonster(7, 2);
